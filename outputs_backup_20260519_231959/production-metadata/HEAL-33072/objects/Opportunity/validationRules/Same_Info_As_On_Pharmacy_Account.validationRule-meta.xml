<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Same_Info_As_On_Pharmacy_Account</fullName>
    <active>true</active>
    <description>Check Pharmacy Name is not empty before applying Same Info As On Pharmacy Account</description>
    <errorConditionFormula>Same_Info_As_On_Account__c  == TRUE &amp;&amp;  Name__c  == NULL</errorConditionFormula>
    <errorDisplayField>Name__c</errorDisplayField>
    <errorMessage>Please Choose a Pharmacy</errorMessage>
</ValidationRule>
