    <description>This flow will run when there is a Transaction Order Id to see if there is a Calendly Action Record that needs to be processed. If there is then the Calendly Action Record will be processed.</description>
    <environments>Default</environments>
    <formulas>
        <name>form_txtCalendlySlug</name>
        <dataType>String</dataType>
        <expression>CASE({!Get_Opportunity_Products.Product_SKU__c}, &apos;BLO-4710-GRO-DRAW&apos;, &apos;blood-draw&apos;, &apos;BLO-4711-GRO-DRAW&apos;,&apos;iv&apos;, &apos;&apos;)</expression>
    </formulas>
