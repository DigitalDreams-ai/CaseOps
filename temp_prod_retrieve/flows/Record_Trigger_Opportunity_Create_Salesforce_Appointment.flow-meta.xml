    <recordLookups>
        <name>Get_Appointment_Records_Tied_to_Opportunity</name>
        <label>Get Appointment Records Tied to Opportunity</label>
        <locationX>385</locationX>
        <locationY>384</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Count_Number_of_Appointments</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Opportunity__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <limit>
            <numberValue>2.0</numberValue>
        </limit>
        <object>Appointment__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Find the Calendly Action Record based on the Object Id field.</description>
        <name>Get_Calendly_Action_Record</name>
        <label>Get Calendly Action Record</label>
        <locationX>539</locationX>
        <locationY>816</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Did_We_Find_Calendly_Action</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Calendly__ObjectId__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Transaction_Source_Order_Number__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>Calendly__EventTypeSlug__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>form_txtCalendlySlug</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Calendly__CalendlyAction__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Opportunity_Products</name>
