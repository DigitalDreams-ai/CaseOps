    <decisions>
        <name>Which_Supplement_Email_To_Send</name>
        <label>Which Supplement Email To Send</label>
        <locationX>446</locationX>
        <locationY>252</locationY>
        <defaultConnectorLabel>Do Not Send Email</defaultConnectorLabel>
        <rules>
            <name>NURTURE_1</name>
            <conditionLogic>(1 OR 2)  AND 3</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Number_of_Supplement_Nurture_Emails_Sent__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Last_Supplement_Nurture_Email_Sent__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>form_NumDaysSinceLastSupplementNurtureEmailSent</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>2.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Email_Template_Nurture_1</targetReference>
            </connector>
            <label>NURTURE 1</label>
        </rules>
        <rules>
            <name>NURTURE_2</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Number_of_Supplement_Nurture_Emails_Sent__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>form_NumDaysSinceLastSupplementNurtureEmailSent</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>3.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Email_Template_Nurture_2</targetReference>
            </connector>
            <label>NURTURE 2</label>
        </rules>
        <rules>
            <name>NURTURE_3</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Number_of_Supplement_Nurture_Emails_Sent__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>2.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>form_NumDaysSinceLastSupplementNurtureEmailSent</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>3.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Email_Template_Nurture_3</targetReference>
            </connector>
            <label>NURTURE 3</label>
        </rules>
    </decisions>
    <description>This scheduled flow will run every day at *** and will send out nurture emails to Accounts who recently purchased a new GT Test Opportunity and received the results. A Supplement Nurture email will be sent out 2 days after GT Oppty is Closed Won ( Results Sent to Client ), 3 Days After previous Supplement Nurture Email Sent, 3 Days After previous Nurture Email Sent. 

If they purchase a Supplement before the end of this nurture no new Supplement nurture emails will be sent.</description>
    <environments>Default</environments>
    <formulas>
        <name>form_NumDaysSinceLastSupplementNurtureEmailSent</name>
        <dataType>Number</dataType>
        <expression>IF ( ISNULL({!$Record.Last_Supplement_Nurture_Email_Sent__c}), 0,
CEILING( TODAY() - DATEVALUE({!$Record.Last_Supplement_Nurture_Email_Sent__c})))</expression>
        <scale>2</scale>
    </formulas>
