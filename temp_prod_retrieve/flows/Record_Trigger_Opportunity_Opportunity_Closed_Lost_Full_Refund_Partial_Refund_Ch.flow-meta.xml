    <description>This flow will run whenever the opportunity is closed lost due to a full refund or when there is a partial refund and create a negative commission record when appropriate.</description>
    <environments>Default</environments>
    <formulas>
        <name>form_Type</name>
        <dataType>String</dataType>
        <expression>IF(ISPICKVAL({!$Record.Closed_Lost_Reason__c},&quot;Patient Chargeback&quot;), &quot;Chargeback&quot;, &quot;Refund&quot;)</expression>
    </formulas>
    <formulas>
        <description>Depending on how the opportunity is setup we will determine if this is a full refund or not.</description>
        <name>form_TypeOfRefund</name>
        <dataType>String</dataType>
        <expression>IF(  
  AND( /** Here we check if the opportunity reason is Patient Refuned, Closed, and not won **/
    ISPICKVAL({!$Record.Closed_Lost_Reason__c},&quot;Patient Refunded&quot;),
    {!$Record.IsClosed},
    NOT({!$Record.IsWon}),
    {!$Record.Opportunity_Refunded__c}
  ),
  &quot;Full Refund&quot;,
  IF( /** Here we check if partial is true. If this is then partial refund else full refund **/
    {!$Record.Opportunity_Partial_Refunded__c},
    &quot;Partial Refund&quot;,
    &quot;&quot;
  )
)</expression>
    </formulas>
    <formulas>
        <name>txt_CurrentMonth</name>
        <dataType>String</dataType>
        <expression>TEXT(MONTH(TODAY()))</expression>
    </formulas>
    <formulas>
        <name>txt_CurrentYear</name>
        <dataType>String</dataType>
        <expression>TEXT(YEAR(TODAY()))</expression>
    </formulas>
    <interviewLabel>Record Trigger - Opportunity - Opportunity Closed Lost | Full Refund | Partial Refund | Chargeback (Clawback) {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Opportunity - Opportunity Closed Lost | Full Refund | Partial Refund</label>
