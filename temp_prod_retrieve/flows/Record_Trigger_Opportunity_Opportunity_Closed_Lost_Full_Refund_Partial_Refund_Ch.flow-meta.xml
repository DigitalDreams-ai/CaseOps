            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Account</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>386</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Commissions</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>AND(
  {!$Setup.AutomationControlSettings__c.Commissions_Automations_Activated__c},
  OR(
    AND(
      ISPICKVAL({!$Record.StageName},&quot;Closed Lost&quot;),
      ISPICKVAL({!$Record.Closed_Lost_Reason__c}, &quot;Patient Refunded&quot;),
      {!$Record.Opportunity_Refunded__c}
    ),
    {!$Record.Opportunity_Partial_Refunded__c}
  )
)</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
