<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Set_Flag_For_Has_Hit_the_Stage_Approved</name>
        <label>Set Flag For Has Hit the Stage Approved</label>
        <locationX>792</locationX>
        <locationY>827</locationY>
        <assignmentItems>
            <assignToReference>bool_HasBeenApproved</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Thru_Opportunity_Field_History</targetReference>
        </connector>
    </assignments>
    <customErrors>
        <name>Error_Opportunity_Has_Been_Approved</name>
        <label>Error - Opportunity Has Been Approved</label>
        <locationX>440</locationX>
        <locationY>1487</locationY>
        <customErrorMessages>
            <errorMessage>The Referred By can not be changed since the Opportunity has already been approved.</errorMessage>
            <isFieldError>false</isFieldError>
        </customErrorMessages>
    </customErrors>
    <decisions>
        <name>Does_User_Have_Right_to_Change_Referred_By</name>
        <label>Does User Have Right to Change Referred By</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <defaultConnector>
            <targetReference>Is_Opportunity_Currently_in_Approved</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>User doesn&apos;t have permissions</defaultConnectorLabel>
        <rules>
            <name>User_has_Permissions</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$User.Can_change_referred_by_after_approved__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <label>User has Permissions</label>
        </rules>
    </decisions>
    <decisions>
        <name>Has_the_Stage_Hit_Approved</name>
        <label>Has the Stage Hit Approved</label>
        <locationX>924</locationX>
        <locationY>719</locationY>
        <defaultConnector>
            <targetReference>Loop_Thru_Opportunity_Field_History</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Another Stage</defaultConnectorLabel>
        <rules>
            <name>Stage_Is_Appproved</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Thru_Opportunity_Field_History.NewValue</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Thru_Opportunity_Field_History.OldValue</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Flag_For_Has_Hit_the_Stage_Approved</targetReference>
            </connector>
            <label>Stage Is Appproved</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Flag_Set_True</name>
        <label>Is Flag Set True</label>
        <locationX>704</locationX>
        <locationY>1103</locationY>
        <defaultConnectorLabel>Flag Set FALSE</defaultConnectorLabel>
        <rules>
            <name>Flag_Set_TRUE</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>bool_HasBeenApproved</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Error_Opportunity_Has_Been_Approved</targetReference>
            </connector>
            <label>Flag Set TRUE</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Opportunity_Currently_in_Approved</name>
        <label>Is Opportunity Currently in Approved</label>
        <locationX>440</locationX>
        <locationY>395</locationY>
        <defaultConnector>
            <targetReference>Get_Opportunity_Field_History</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Opportunity Stage Not Approved</defaultConnectorLabel>
        <rules>
            <name>Opportunity_Stage_Approved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Error_Opportunity_Has_Been_Approved</targetReference>
            </connector>
            <label>Opportunity Stage = Approved</label>
        </rules>
    </decisions>
    <description>This flow is a validation rule to ensure that the Opportunity Referred By field can not be changed after the opportunity has been approved. If the Opportunity has been approved and the referred by is being changed throw an error.</description>
    <environments>Default</environments>
    <interviewLabel>Record Trigger - Opportunity - Validation - Can&apos;t Change Referred By After Approved {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Opportunity - Validation - Can&apos;t Change Referred By After Approved</label>
    <loops>
        <name>Loop_Thru_Opportunity_Field_History</name>
        <label>Loop Thru Opportunity Field History</label>
        <locationX>704</locationX>
        <locationY>611</locationY>
        <collectionReference>Get_Opportunity_Field_History</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Has_the_Stage_Hit_Approved</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Is_Flag_Set_True</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Here we will get all of the opportunity field history and then after we will see if there was ever a stage of approved. If so then we error out.</description>
        <name>Get_Opportunity_Field_History</name>
        <label>Get Opportunity Field History</label>
        <locationX>704</locationX>
        <locationY>503</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Thru_Opportunity_Field_History</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>OpportunityId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Field</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>StageName</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>OpportunityFieldHistory</object>
        <sortField>CreatedDate</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Does_User_Have_Right_to_Change_Referred_By</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Referred_By__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Opportunity</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
    <triggerOrder>60</triggerOrder>
    <variables>
        <name>bool_HasBeenApproved</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <booleanValue>false</booleanValue>
        </value>
    </variables>
</Flow>
