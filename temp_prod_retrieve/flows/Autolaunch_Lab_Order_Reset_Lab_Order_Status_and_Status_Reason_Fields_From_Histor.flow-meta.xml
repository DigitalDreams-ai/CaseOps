    <decisions>
        <description>New Lab order coming in from MWP come with the status Patient Received Kit and should not be reset to Pending Fulfillment</description>
        <name>Is_it_a_new_Patient_Received_Kit_order</name>
        <label>Is it a new Patient Received Kit order</label>
        <locationX>446</locationX>
        <locationY>458</locationY>
        <defaultConnector>
            <targetReference>Log_No_Status_found</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Patient_Received_Kit</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rec_LabOrder.Status_Reason__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Patient Received Kit</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Debug_Patient_Received_Kit</targetReference>
            </connector>
            <label>Patient Received Kit</label>
        </rules>
    </decisions>
