        </defaultConnector>
        <defaultConnectorLabel>No Status Reason Found</defaultConnectorLabel>
        <rules>
            <name>Status_Reason_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Latest_Status_Reason</leftValueReference>
