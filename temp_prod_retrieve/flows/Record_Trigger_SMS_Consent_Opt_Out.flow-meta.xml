<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Update_SMS_Opt_Out</name>
        <label>Update SMS Opt Out by Phone</label>
        <locationX>308</locationX>
        <locationY>276</locationY>
        <actionName>SMSConsentOptOutHandler</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>phoneNumber</name>
            <value>
                <elementReference>$Record.Name</elementReference>
            </value>
        </inputParameters>
        <nameSegment>SMSConsentOptOutHandler</nameSegment>
    </actionCalls>
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>When SMS Magic creates or updates a Consent record with Compliance Status = Opt-Out, normalizes the phone number from the Name field and updates SMS opt-out on all matching Accounts and Leads.</description>
    <environments>Default</environments>
    <interviewLabel>Record Trigger - SMS Consent Opt-Out {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - SMS Consent Opt-Out</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>182</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_SMS_Opt_Out</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>smagicinteract__Compliance_Status__c</field>
