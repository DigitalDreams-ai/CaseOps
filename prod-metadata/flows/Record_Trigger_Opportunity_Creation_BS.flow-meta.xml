<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Account_Name</name>
        <label>Assign Account Name</label>
        <locationX>578</locationX>
        <locationY>503</locationY>
        <assignmentItems>
            <assignToReference>txt_AccountName</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Account.Name</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_The_Opportunity_Name</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Is_Secondary_Lead_Source_Set</name>
        <label>Is Secondary Lead Source Set</label>
        <locationX>182</locationX>
        <locationY>503</locationY>
        <defaultConnectorLabel>No Secondary Lead Source Set</defaultConnectorLabel>
        <rules>
            <name>Secondary_Lead_Source_Set</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Secondary_Lead_Source__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Secondary_Lead_Source_from_Account</targetReference>
            </connector>
            <label>Secondary Lead Source Set</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_The_Record_Created_or_Updated</name>
        <label>Is The Record Created or Updated</label>
        <locationX>380</locationX>
        <locationY>287</locationY>
        <defaultConnector>
            <targetReference>Get_Account</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Record Is Updated</defaultConnectorLabel>
        <rules>
            <name>Record_Is_Created</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>form_IsCreated</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Default_Values_on_Opportunity</targetReference>
            </connector>
            <label>Record Is Created</label>
        </rules>
    </decisions>
    <description>Update to run on Update of the Account Name and on Creation of the Opportunity Record. Spacing different</description>
    <environments>Default</environments>
    <formulas>
        <description>This will return true if it is a new record.</description>
        <name>form_IsCreated</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>form_numPatientAge</name>
        <dataType>Number</dataType>
        <expression>IF(
MONTH(TODAY())&gt;MONTH({!$Record.Account.DateOfBirth__c}),
YEAR(TODAY())-YEAR({!$Record.Account.DateOfBirth__c}),
IF(AND(MONTH(TODAY()) = MONTH({!$Record.Account.DateOfBirth__c}), DAY(TODAY()) &gt;= DAY({!$Record.Account.DateOfBirth__c})),
YEAR(TODAY())-YEAR({!$Record.Account.DateOfBirth__c}),
(YEAR(TODAY())-YEAR({!$Record.Account.DateOfBirth__c}))-1)
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>form_OpportunityNameUpdate</name>
        <dataType>String</dataType>
        <expression>LEFT(SUBSTITUTE({!txt_AccountName}, &quot; &quot;, &quot;&quot;) &amp; SUBSTITUTE({!$Record.RecordType.Name}, &quot; &quot;, &quot; &quot;), 70) &amp; RIGHT({!$Record.Name}, 10)</expression>
    </formulas>
    <formulas>
        <name>form_txtOpptyName</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE({!$Record.Account.FirstName} + {!$Record.Account.LastName}, &quot; &quot;, &quot;&quot;) + {!$Record.RecordType.Name} + TEXT(TODAY())</expression>
    </formulas>
    <formulas>
        <name>form_txtOriginalOpptyOwner</name>
        <dataType>String</dataType>
        <expression>{!$Record.CreatedBy.FirstName} + &quot; &quot;+{!$Record.CreatedBy.LastName}</expression>
    </formulas>
    <interviewLabel>Record Trigger - Opportunity - Creation BS {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Opportunity - Creation BS</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Account</name>
        <label>Get Account</label>
        <locationX>578</locationX>
        <locationY>395</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Assign_Account_Name</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.AccountId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Account</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Set_Default_Values_on_Opportunity</name>
        <label>Set Default Values on Opportunity</label>
        <locationX>182</locationX>
        <locationY>395</locationY>
        <connector>
            <targetReference>Is_Secondary_Lead_Source_Set</targetReference>
        </connector>
        <inputAssignments>
            <field>LeadSource</field>
            <value>
                <elementReference>$Record.Account.Lead_Source__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>form_txtOpptyName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Original_Opp_Owner__c</field>
            <value>
                <elementReference>form_txtOriginalOpptyOwner</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Patient_Age__c</field>
            <value>
                <elementReference>form_numPatientAge</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Patient_Date_Of_Birth__c</field>
            <value>
                <elementReference>$Record.Account.DateOfBirth__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Patient_Driver_s_License__c</field>
            <value>
                <elementReference>$Record.Account.Driver_s_License__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Patient_Email__c</field>
            <value>
                <elementReference>$Record.Account.PersonEmail</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Patient_Mobile_Phone__c</field>
            <value>
                <elementReference>$Record.Account.PersonMobilePhone</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Patient_Phone__c</field>
            <value>
                <elementReference>$Record.Account.Phone</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Set_Secondary_Lead_Source_from_Account</name>
        <label>Set Secondary Lead Source from Account</label>
        <locationX>50</locationX>
        <locationY>611</locationY>
        <inputAssignments>
            <field>Secondary_Lead_Source__c</field>
            <value>
                <elementReference>$Record.Account.Secondary_Lead_Source__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_The_Opportunity_Name</name>
        <label>Update The Opportunity Name</label>
        <locationX>578</locationX>
        <locationY>611</locationY>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>form_OpportunityNameUpdate</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>254</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_The_Record_Created_or_Updated</targetReference>
        </connector>
        <filterFormula>ISNEW() || ISCHANGED({!$Record.AccountId})</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Draft</status>
    <triggerOrder>200</triggerOrder>
    <variables>
        <name>txt_AccountName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
</Flow>
