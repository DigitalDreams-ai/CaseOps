<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Checks to see if there are files to delete prior to firing trigger</description>
        <name>Are_There_Files_To_Delete</name>
        <label>Are There Files To Delete</label>
        <locationX>1294</locationX>
        <locationY>587</locationY>
        <defaultConnector>
            <targetReference>Re_Send_New_Patient_Agreements</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Files To Delete</defaultConnectorLabel>
        <rules>
            <name>Files_to_Delete</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_All_Patient_Agreements_No_Biocanic_Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Delete_Existing_Patient_Agreements</targetReference>
            </connector>
            <label>Files to Delete</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks to see if the Account Has already been synced. If so this will then send the patients their initial forms again.</description>
        <name>Does_Account_Have_Biocanic_Id</name>
        <label>Does Account Have Biocanic Id</label>
        <locationX>1096</locationX>
        <locationY>371</locationY>
        <defaultConnectorLabel>Account Has Biocanic Id</defaultConnectorLabel>
        <rules>
            <name>Account_Doesn_t_Have_Biocanic_Id</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Biocanic_External_Id__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Patient_Portal_Account</targetReference>
            </connector>
            <label>Account Doesn&apos;t Have Biocanic Id</label>
        </rules>
    </decisions>
    <description>This flow watches when the TRIG Sync to PP field is marked TRUE. When this criteria is met then the it will call the subflow to create the Patient Portal Account.</description>
    <environments>Default</environments>
    <interviewLabel>TEMP -- Record Trigger - Backfill Patient Portal Accounts {!$Flow.CurrentDateTime}</interviewLabel>
    <label>TEMP -- Record Trigger - Backfill Patient Portal Accounts</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordDeletes>
        <description>We are going to delete these because we didn&apos;t get a Biocanic Id and they didn&apos;t get assigned in Biocanic.</description>
        <name>Delete_Existing_Patient_Agreements</name>
        <label>Delete Existing Patient Agreements</label>
        <locationX>1162</locationX>
        <locationY>695</locationY>
        <connector>
            <targetReference>Re_Send_New_Patient_Agreements</targetReference>
        </connector>
        <inputReference>Get_All_Patient_Agreements_No_Biocanic_Id</inputReference>
    </recordDeletes>
    <recordLookups>
        <description>We want to get all of the Patient Agreements that Don&apos;t have a Biocanic Id and delete the before creating new ones.</description>
        <name>Get_All_Patient_Agreements_No_Biocanic_Id</name>
        <label>Get All Patient Agreements - No Biocanic Id</label>
        <locationX>1294</locationX>
        <locationY>479</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Are_There_Files_To_Delete</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Biocanic_Id__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Sent</stringValue>
            </value>
        </filters>
        <filters>
            <field>IsDeleted</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Patient_Agreement__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>970</locationX>
        <locationY>48</locationY>
        <connector>
            <targetReference>Does_Account_Have_Biocanic_Id</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>and</filterLogic>
        <filters>
            <field>TRIG_SYNC_TO_PP__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Account</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Obsolete</status>
    <subflows>
        <name>Create_Patient_Portal_Account</name>
        <label>Create Patient Portal Account</label>
        <locationX>898</locationX>
        <locationY>479</locationY>
        <flowName>Autolaunch_Account_Sync_To_External_Systems</flowName>
        <inputAssignments>
            <name>bool_IsNew</name>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>rec_Account</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>txt_EventType</name>
            <value>
                <stringValue>CreateAccount</stringValue>
            </value>
        </inputAssignments>
    </subflows>
    <subflows>
        <description>Will only send the Patient Agreements that are marked for New Patients.</description>
        <name>Re_Send_New_Patient_Agreements</name>
        <label>Re-Send New Patient Agreements</label>
        <locationX>1294</locationX>
        <locationY>887</locationY>
        <flowName>Autolaunch_Send_Patient_Agreements_New_Patient</flowName>
        <inputAssignments>
            <name>rec_Account</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
    </subflows>
</Flow>
