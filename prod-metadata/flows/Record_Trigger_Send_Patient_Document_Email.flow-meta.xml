    <decisions>
        <description>Here, we check to see if the email address has bounced. If it has, we won&apos;t send an email.</description>
        <name>Is_Email_Bounced</name>
        <label>Is Email Bounced</label>
        <locationX>677</locationX>
        <locationY>827</locationY>
        <defaultConnector>
            <targetReference>Is_there_a_patient_assigned_to_the_Patient_Agreement</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Email is Valid</defaultConnectorLabel>
        <rules>
            <name>Email_is_Bounced</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Patient__r.PersonEmailBouncedDate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Error_Email_Bounced</targetReference>
            </connector>
            <label>Email is Bounced</label>
        </rules>
        <rules>
            <name>Email_template_is_missing</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>txt_EmailTemplate</leftValueReference>
                <operator>EqualTo</operator>
            </conditions>
            <conditions>
                <leftValueReference>txt_EmailTemplate</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Error_Email_Template_Missing</targetReference>
            </connector>
            <label>Email template is missing</label>
        </rules>
    </decisions>
