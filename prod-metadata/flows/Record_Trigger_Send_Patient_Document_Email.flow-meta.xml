    <description>This flow will send the intial reminder and sny reminder emails to the patient.</description>
    <environments>Default</environments>
    <formulas>
        <name>form_EmailTemplate1</name>
        <dataType>String</dataType>
        <expression>IF(
    OR(
        {!$Record.Patient__r.Do_Not_Sync_to_Biocanic__c},
        {!$Setup.AutomationControlSettings__c.Do_Not_Sync_to_Biocanic__c}
    ),
    {!$Record.Patient_Agreement_Configuration__r.First_Email__c},
    IF(
        ISBLANK({!$Record.Patient_Agreement_Configuration__r.First_Email__c}),
        &apos;Consent_Assigned_NEW_1710959119814&apos;,
        IF(
            NOT({!$Record.Patient__r.Do_Not_Sync_to_Biocanic__c}) 
            &amp;&amp; NOT({!$Setup.AutomationControlSettings__c.Do_Not_Sync_to_Biocanic__c}),
            &apos;Consent_Assigned_NEW_1710959119814&apos;,
            {!$Record.Patient_Agreement_Configuration__r.First_Email__c}
        )
    )
)</expression>
