    <decisions>
        <description>Check if the lab order is Precision Supplement lab order. Execute immediately if Lab_Request_SKU__c = 10X-PRECISION-AMINOS</description>
        <name>Is_it_a_Precision_Supplement_Order</name>
        <label>Is it a Precision Supplement Order</label>
        <locationX>374</locationX>
        <locationY>276</locationY>
        <defaultConnector>
            <targetReference>Log_Flow_Entry</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not PGT Order</defaultConnectorLabel>
        <rules>
            <name>PGT_Order</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Services_Rendered__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Precision Supplements</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Product__r.Lab_Request_SKU__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>10X-PRECISION-AMINOS</stringValue>
                </rightValue>
            </conditions>
            <label>PGT Order</label>
        </rules>
    </decisions>
