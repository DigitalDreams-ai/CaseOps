        <rules>
            <name>PGT_Kit_is_not_Registered</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rec_LabOrder.Is_Kit_Registered__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Create_Collection_of_Requested_Items.rec_OpportunityLineItem.PricebookEntry.Product2.Services_Provided__c</leftValueReference>
