                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asn_Stamp_Sample_Received</targetReference>
            </connector>
            <label>Status - Sample Received</label>
        </rules>
    </decisions>
    <decisions>
        <name>Dec_Which_Stamp_Status_Reason_Changes</name>
        <label>Which Stamp for Status Reason Changes?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Match</defaultConnectorLabel>
        <rules>
            <name>Status_Reason_Kit_Sent_to_Patient</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status_Reason__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Kit Sent To Patient</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asn_Stamp_Kit_Sent_to_Patient</targetReference>
            </connector>
            <label>Status Reason - Kit Sent to Patient (Status Reason Path)</label>
        </rules>
        <rules>
            <name>Status_Reason_Analysis_in_Progress</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status_Reason__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Analysis In Progress</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asn_Stamp_Analysis_in_Progress</targetReference>
            </connector>
            <label>Status Reason - Analysis in Progress (Status Reason Path)</label>
        </rules>
        <rules>
            <name>Status_Reason_Order_Processing</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status_Reason__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Supplement Production Started</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asn_Stamp_Supplement_Production_Started</targetReference>
            </connector>
            <label>Status Reason - Order Processing (Status Reason Path)</label>
        </rules>
        <rules>
            <name>Status_Reason_Sent_to_Distribution_Center</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status_Reason__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Product Sent to Distribution Center</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asn_Stamp_Product_Sent_to_Distribution_Center</targetReference>
            </connector>
            <label>Status Reason - Sent to Distribution Center (Status Reason Path)</label>
        </rules>
        <rules>
            <name>Status_Reason_Sample_Received_by_Distribution</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status_Reason__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sample Received by Distribution</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asn_Stamp_Sample_Received_by_Distribution</targetReference>
            </connector>
            <label>Status Reason - Sample Received by Distribution (Status Reason Path)</label>
        </rules>
    </decisions>
    <decisions>
        <description>Here we check if the Status Reason changed as well; if so we need to evaluate those statues as well.</description>
        <name>Was_Status_Reason_Changed_As_Well</name>
        <label>Was Status Reason Changed As Well</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Status Reason NOT Changed</defaultConnectorLabel>
        <rules>
            <name>Status_Reason_Changed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status_Reason__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Dec_Which_Stamp_Status_Reason_Changes</targetReference>
            </connector>
            <label>Status Reason Changed</label>
        </rules>
    </decisions>
    <decisions>
        <description>This will navigate to the correct stamp to hit</description>
        <name>Which_Field_Changed</name>
        <label>Which Field Changed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Not Tracked</defaultConnectorLabel>
        <rules>
            <name>Status</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Dec_Which_Stamp_Status_Changes</targetReference>
            </connector>
            <label>Status</label>
        </rules>
        <rules>
            <name>Status_Reason</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status_Reason__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Dec_Which_Stamp_Status_Reason_Changes</targetReference>
            </connector>
            <label>Status Reason</label>
        </rules>
    </decisions>
    <description>Stamp Date/Time fields on Lab_Order__c when Status__c or Status_Reason__c changes.</description>
    <environments>Default</environments>
    <interviewLabel>Record Trigger - Lab Order - Timetrack {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Lab Order - Timetrack</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Dec_Did_Status_or_Reason_Change</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>Status__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Status_Reason__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Lab_Order__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
