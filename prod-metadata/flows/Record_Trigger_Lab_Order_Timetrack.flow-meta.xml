    <decisions>
        <name>Dec_Did_Status_or_Reason_Change</name>
        <label>Did Status or Reason Change?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Change</defaultConnectorLabel>
        <rules>
            <name>Yes_Changed</name>
            <conditionLogic>1 OR 2</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.Status__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status_Reason__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.Status_Reason__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Which_Field_Changed</targetReference>
            </connector>
            <label>Yes - Changed</label>
        </rules>
    </decisions>
    <decisions>
        <name>Dec_Which_Stamp_Status_Changes</name>
        <label>Which Stamp for Status Changes?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Was_Status_Reason_Changed_As_Well</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Match</defaultConnectorLabel>
        <rules>
            <name>Status_Results_Delivered</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Results Delivered</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asn_Stamp_Results_Delivered</targetReference>
            </connector>
            <label>Status - Results Delivered</label>
        </rules>
        <rules>
            <name>Status_Reason_Order_Held</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Order Held</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asn_Stamp_Order_Held</targetReference>
            </connector>
            <label>Status Reason - Order Held</label>
        </rules>
        <rules>
            <name>Status_Sample_Received</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
