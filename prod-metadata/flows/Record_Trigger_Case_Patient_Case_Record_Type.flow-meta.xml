    <recordLookups>
        <name>Check_if_user_is_Tier_two_agent</name>
        <label>Check if user is Tier two agent</label>
        <locationX>1172</locationX>
        <locationY>395</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Decision_2</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Tier_Group__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Tier Two</stringValue>
            </value>
        </filters>
        <filters>
            <field>Agent_SF_ID__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$User.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Out_of_Office__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Case_Agents_Assignment__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>716</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>What_Subject_Text</targetReference>
        </connector>
        <filterFormula>OR(

    AND(
        OR(
            BEGINS({!$Record.Subject}, &quot;Shipping Information Reconciliation&quot;),
            BEGINS({!$Record.Subject}, &quot;Patient Information Reconciliation&quot;),
            BEGINS({!$Record.Subject}, &quot;Payment Record Reconciliation&quot;)
        ),
        {!$Record.RecordType.Name} = &quot;Patient Case Record Type&quot;
    ),


    AND(
        {!$Record.RecordType.DeveloperName} = &quot;Customer_Experience&quot;,
        TEXT({!$Record.Status}) &lt;&gt; &quot;Closed&quot;,
        TEXT({!$Record.Status}) &lt;&gt; &quot;Completed&quot;,
        TEXT({!$Record.Status}) &lt;&gt; &quot;Merged&quot;
    )
)</filterFormula>
        <object>Case</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
