<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>56.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Set_Is_Supplement_to_True_Default</name>
        <label>Set Is Supplement to True - Default</label>
        <locationX>176</locationX>
        <locationY>395</locationY>
        <assignmentItems>
            <assignToReference>boolIsSupplement</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Through_Products</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_IsSupplement_to_False</name>
        <label>Set IsSupplement to False</label>
        <locationX>440</locationX>
        <locationY>719</locationY>
        <assignmentItems>
            <assignToReference>boolIsSupplement</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Through_Products</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>Check if the Product belongs to the Supplement family, Shipping or Sales Tax. 
If true do nothing
If false, set IsSupplement flag to false</description>
        <name>Is_Product_A_Supplement</name>
        <label>Is Product A Supplement</label>
        <locationX>352</locationX>
        <locationY>611</locationY>
        <defaultConnector>
            <targetReference>Set_IsSupplement_to_False</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Non Supplement Product</defaultConnectorLabel>
        <rules>
            <name>Supplement_Product</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Through_Products.Product2.Family</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Supplements</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Through_Products.Product2.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sales Tax</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Through_Products.Product2.Sub_Product_Family__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Shipping</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Through_Products</targetReference>
            </connector>
            <label>Supplement Product</label>
        </rules>
    </decisions>
    <description>If an opportunity product is deleted, check the rest of the products related to the Opportunity and mark the Is Supplement flag if necessary</description>
    <environments>Default</environments>
    <interviewLabel>RecordTrigger - Opportunity Product Delete - Set Is Supplement Field on Opportunity {!$Flow.CurrentDateTime}</interviewLabel>
    <label>RecordTrigger - Opportunity Product Delete - Set Is Supplement Field on Opportunity</label>
    <loops>
        <name>Loop_Through_Products</name>
        <label>Loop Through Products</label>
        <locationX>176</locationX>
        <locationY>503</locationY>
        <collectionReference>Get_All_Products_on_Oppty</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Is_Product_A_Supplement</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
