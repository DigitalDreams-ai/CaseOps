        <connector>
            <targetReference>Find_Event_for_Appointment</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Did_We_Find_Event_Record</name>
        <label>Did We Find Event Record</label>
        <locationX>182</locationX>
        <locationY>503</locationY>
        <defaultConnector>
            <targetReference>Reduce_the_Number_of_Appointments</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Event Record Found</defaultConnectorLabel>
        <rules>
            <name>Event_Record_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Find_Event_for_Appointment</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Delete_Event</targetReference>
            </connector>
            <label>Event Record Found</label>
        </rules>
    </decisions>
    <description>To ensure we keep the data clean and incase an appointment is deleted we want to ensure that we delete any related event records as well to ensure the event gets removed from the Office 365 Calendar.</description>
    <environments>Default</environments>
    <interviewLabel>Record Trigger - Appointment - Delete Event when Appointment is Deleted {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Appointment - Delete Event when Appointment is Deleted</label>
    <processMetadataValues>
