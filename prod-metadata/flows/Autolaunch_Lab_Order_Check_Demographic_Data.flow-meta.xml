            </conditions>
            <connector>
                <targetReference>Does_Demographic_Data_Match_PGT</targetReference>
            </connector>
            <label>PGT/GT</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <description>Formula to generate Lab Order Full name without whitespaces</description>
        <name>form_txt_LabOrder_FullNameNoWS</name>
        <dataType>String</dataType>
        <expression>LOWER(SUBSTITUTE({!rec_LabOrder.First_Name__c}+{!rec_LabOrder.Last_Name__c},&quot; &quot;,&quot;&quot;))</expression>
    </formulas>
    <formulas>
        <description>Formula to generate Lab Order.Patient Full name without whitespaces</description>
        <name>form_txt_LabOrderPatientFullNameNoWS</name>
        <dataType>String</dataType>
        <expression>LOWER(SUBSTITUTE( {!rec_LabOrder.Patient__r.FirstName}+{!rec_LabOrder.Patient__r.LastName},&quot; &quot;,&quot;&quot;))</expression>
    </formulas>
    <formulas>
        <name>form_txtMismatchedValues</name>
        <dataType>String</dataType>
        <expression>IF(
    UPPER(TEXT({!rec_LabOrder.Patient__r.Gender__c})) != UPPER(TEXT({!rec_LabOrder.Gender__c})),
    &quot;❌ Gender Mismatch&quot; &amp; BR(),
    &quot;&quot;
) &amp; 
IF(
    UPPER({!rec_LabOrder.Patient__r.FirstName}) != UPPER({!rec_LabOrder.First_Name__c}) ||
    UPPER({!rec_LabOrder.Patient__r.LastName}) != UPPER({!rec_LabOrder.Last_Name__c}),
    &quot;❌ Name Mismatch&quot; &amp; BR(),
    &quot;&quot;
) &amp; 
IF(
    {!rec_LabOrder.Patient__r.DateOfBirth__c} != {!rec_LabOrder.Date_of_Birth__c},
    &quot;❌ DOB Mismatch&quot; &amp; BR(),
    &quot;&quot;
)</expression>
    </formulas>
