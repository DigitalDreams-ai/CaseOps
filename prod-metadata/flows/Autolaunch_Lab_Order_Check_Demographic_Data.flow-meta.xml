    <decisions>
        <name>Does_Demographic_Data_Match_PGT</name>
        <label>Does Demographic Data Match</label>
        <locationX>182</locationX>
        <locationY>350</locationY>
        <defaultConnector>
            <targetReference>Log_Demographic_Match</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Match</defaultConnectorLabel>
        <rules>
            <name>Doesn_t_Match</name>
            <conditionLogic>((1 OR 2 ) AND 5) OR (3 OR 4)</conditionLogic>
            <conditions>
                <leftValueReference>rec_LabOrder.First_Name__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>rec_LabOrder.Patient__r.FirstName</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rec_LabOrder.Last_Name__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>rec_LabOrder.Patient__r.LastName</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rec_LabOrder.Gender__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>rec_LabOrder.Patient__r.Gender__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rec_LabOrder.Date_of_Birth__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>rec_LabOrder.Patient__r.DateOfBirth__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>form_txt_LabOrder_FullNameNoWS</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>form_txt_LabOrderPatientFullNameNoWS</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Error</targetReference>
            </connector>
            <label>Doesn&apos;t Match</label>
        </rules>
    </decisions>
