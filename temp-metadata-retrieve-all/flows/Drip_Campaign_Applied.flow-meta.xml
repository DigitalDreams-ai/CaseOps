<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>49.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>With Survey&apos;s we need to find the First Question ID because we don&apos;t want  the user to have to define the question ID since it&apos;s almost  impossible to choose because of the bad Question Name field.</description>
        <name>Survey</name>
        <label>Survey?</label>
        <locationX>354</locationX>
        <locationY>219</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Survey_YES</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recDripCampaignMessage.Survey__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Survey_Question</targetReference>
            </connector>
            <label>YES</label>
        </rules>
        <rules>
            <name>Survey_NO</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recDripCampaignMessage.Survey__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Scheduled_SMS</targetReference>
            </connector>
            <label>NO</label>
        </rules>
    </decisions>
    <description>When a Drip Campaign is set on the Lead or Contact a PB calls this Flow passing in the Drip Campaign Id, the Contact</description>
    <formulas>
        <description>Each customer could have different Phone fields defined per object so best to use this formula to keep the logic concentrated here and keep the Create Records generic using the formula</description>
        <name>fPhoneAPI</name>
        <dataType>String</dataType>
        <expression>IF( ISNULL({!vContactId}) || ISBLANK({!vContactId}),&apos;MobilePhone&apos;, &apos;MobilePhone&apos;)</expression>
    </formulas>
    <formulas>
        <description>Defines whether the incoming record Id from the Process Builder is a Contact, Lead or Opportunity</description>
        <name>fRecordId</name>
        <dataType>String</dataType>
        <expression>IF( ISNULL({!vContactId}) || ISBLANK({!vContactId}), {!vLeadId}, {!vContactId})</expression>
    </formulas>
    <interviewLabel>Drip Campaign Applied {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Drip Campaign Applied</label>
    <loops>
        <description>Loop through the messages and add them to the Scheduled SMS</description>
        <name>Loop_Messages</name>
        <label>Loop Messages</label>
        <locationX>363</locationX>
        <locationY>47</locationY>
        <assignNextValueToReference>recDripCampaignMessage</assignNextValueToReference>
        <collectionReference>CollectionOfDripMessages</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Survey</targetReference>
        </nextValueConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Create the scheduled SMS</description>
        <name>Scheduled_SMS</name>
        <label>Scheduled SMS</label>
        <locationX>582</locationX>
        <locationY>137</locationY>
        <connector>
            <targetReference>Loop_Messages</targetReference>
        </connector>
        <inputAssignments>
            <field>Drip_Campaign__c</field>
            <value>
                <elementReference>vDripCampaignId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>fRecordId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>tdc_tsw__Contact__c</field>
            <value>
                <elementReference>vContactId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>tdc_tsw__Lead__c</field>
            <value>
                <elementReference>vLeadId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>tdc_tsw__Phone_Api__c</field>
            <value>
                <elementReference>fPhoneAPI</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>tdc_tsw__Question__c</field>
            <value>
                <elementReference>vQuestionId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>tdc_tsw__Related_Object_Id__c</field>
            <value>
                <elementReference>fRecordId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>tdc_tsw__SMS_Template__c</field>
            <value>
                <elementReference>recDripCampaignMessage.SMS_Template__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>tdc_tsw__Scheduled_Time__c</field>
            <value>
                <elementReference>recDripCampaignMessage.Schedule_Date_Time__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>tdc_tsw__Sender_Number__c</field>
            <value>
                <elementReference>vSenderNumber</elementReference>
            </value>
        </inputAssignments>
        <object>tdc_tsw__Scheduled_Sms__c</object>
    </recordCreates>
    <recordLookups>
        <description>Get the drip campaign messages via the ID passed in from a process builder and then loop through them adding each to the Scheduled SMS object.
We only need the Survey, Question, and Schedule_Date_Time (because the Scheduled Date Time is a formula that already computes the Days Offset and Time)</description>
        <name>Drip_Campaign_Messages</name>
        <label>Drip Campaign Messages</label>
        <locationX>214</locationX>
        <locationY>44</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Messages</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Drip_Campaign__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>vDripCampaignId</elementReference>
            </value>
        </filters>
        <object>Drip_Campaign_Message__c</object>
        <outputReference>CollectionOfDripMessages</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>SMS_Template__c</queriedFields>
        <queriedFields>Survey__c</queriedFields>
        <queriedFields>Schedule_Date_Time__c</queriedFields>
        <sortField>Days_Offset__c</sortField>
        <sortOrder>Asc</sortOrder>
    </recordLookups>
    <recordLookups>
        <description>We need to get the First Question of the Survey because the Scheduled SMS needs a question rather than a survey and we don&apos;t  want the user to have to choose the Question in the Drip Campaign Message page layout as it&apos;s almost impossible.</description>
        <name>Survey_Question</name>
        <label>Survey Question</label>
        <locationX>584</locationX>
        <locationY>345</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Scheduled_SMS</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>tdc_tsw__First_Question__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>tdc_tsw__Survey__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recDripCampaignMessage.Survey__c</elementReference>
            </value>
        </filters>
        <object>tdc_tsw__Question__c</object>
        <outputAssignments>
            <assignToReference>vQuestionId</assignToReference>
            <field>Id</field>
        </outputAssignments>
    </recordLookups>
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>Drip_Campaign_Messages</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
        <name>CollectionOfDripMessages</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Drip_Campaign_Message__c</objectType>
    </variables>
    <variables>
        <description>Record  variable holding the current  Drip Campaign Message (the many defined messages of the Drip Campaign definition)</description>
        <name>recDripCampaignMessage</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Drip_Campaign_Message__c</objectType>
    </variables>
    <variables>
        <description>Input variable from the Process Builder could be null if passed in from a Lead or Opportunity</description>
        <name>vContactId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>The drip campaign id passed in from the Process Builder when the user selects which campaign to apply.</description>
        <name>vDripCampaignId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Input variable from the Process Builder could be null if called from the Contact object</description>
        <name>vLeadId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>We get the Question Id from the First Question of the Survey as a variable instead of a record variable so that if it&apos;s null we can simply pass it to the Scheduled SMS creation without additional code.</description>
        <name>vQuestionId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>We need the process builder to pass in the Sender Number so that each customer will have their own business logic such as Sticky_Sender  or pulled from the current  User.SMS_Number</description>
        <name>vSenderNumber</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
