    <decisions>
        <description>Only fires when Opportunity is Open. If Opportunity is Closed, does not affect records</description>
        <name>Inventory_Product_Check</name>
        <label>Inventory Product Check</label>
        <locationX>314</locationX>
        <locationY>311</locationY>
        <defaultConnectorLabel>Non-Inventory</defaultConnectorLabel>
        <rules>
            <name>Update_Inventory</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Product2.Tracked_Inventory__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Inventory_Movement__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Update_Values</targetReference>
            </connector>
            <label>Update Inventory</label>
        </rules>
        <rules>
            <name>New_Product</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Product2.Tracked_Inventory__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Inventory_Movement__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Opportunity.IsClosed</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Create_Values</targetReference>
            </connector>
            <label>New Product</label>
        </rules>
    </decisions>
