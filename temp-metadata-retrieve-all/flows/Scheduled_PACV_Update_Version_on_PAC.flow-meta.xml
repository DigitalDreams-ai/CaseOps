    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Find all Patient Agreement Configurations that use previous version of PACV</description>
        <name>Get_PACs_that_use_previous_version</name>
        <label>Get PACs that use previous version</label>
        <locationX>314</locationX>
        <locationY>684</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Did_we_find_PACs_that_use_old_version</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_Error_Getting_PACs</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Patient_Agreement_Configuration_Version__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_previous_PACV.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Patient_Agreement_Configuration__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Get previous version of PACV that is becoming effective today</description>
