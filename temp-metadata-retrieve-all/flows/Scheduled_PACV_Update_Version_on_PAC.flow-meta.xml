    <decisions>
        <description>Check if we managed to find any PACs using previous version. If yes, they need to be updated</description>
        <name>Did_we_find_PACs_that_use_old_version</name>
        <label>Did we find PACs that use old version</label>
        <locationX>314</locationX>
        <locationY>792</locationY>
        <defaultConnector>
            <targetReference>Log_No_PACs_Using_Previous_Versions_Found</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No PACs found</defaultConnectorLabel>
        <rules>
            <name>Found_PACs_using_old_version</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_PACs_that_use_previous_version</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_through_found_PACs</targetReference>
            </connector>
            <label>Found PACs using old version</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if we found a previous version of PACV</description>
        <name>Is_there_a_previous_version</name>
        <label>Is there a previous version</label>
        <locationX>710</locationX>
        <locationY>468</locationY>
        <defaultConnector>
            <targetReference>Log_No_Previous_Version</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No previous version</defaultConnectorLabel>
        <rules>
            <name>Found_previous_version</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_previous_PACV</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Found_Previous_Version</targetReference>
            </connector>
            <label>Found previous version</label>
        </rules>
    </decisions>
    <description>Runs daily to check if a PACV Effective date has come up. If yes, it checks for PAC that use the old version and updates them to new one</description>
    <environments>Default</environments>
    <formulas>
        <description>Removes last , to format nicely</description>
        <name>txt_FinalUpdatedList</name>
        <dataType>String</dataType>
        <expression>LEFT({!txt_UpdatedPACs}, LEN({!txt_UpdatedPACs}) - 1)</expression>
    </formulas>
    <interviewLabel>Scheduled - PACV - Update Version on PAC {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Scheduled - PACV - Update Version on PAC</label>
    <loops>
        <description>Loop through PACs that used the last version to update them with new values</description>
        <name>Loop_through_found_PACs</name>
        <label>Loop through found PACs</label>
        <locationX>50</locationX>
        <locationY>900</locationY>
        <collectionReference>Get_PACs_that_use_previous_version</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_new_PACV_and_Link_values</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_PACs</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
