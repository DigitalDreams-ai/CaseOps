    <decisions>
        <description>This decision checks to see if the case was created from a web form and is a Customer Experience Case</description>
        <name>CX_Case_from_Web_Form</name>
        <label>CX Case from Web Form?</label>
        <locationX>182</locationX>
        <locationY>276</locationY>
        <defaultConnectorLabel>Not CX Case</defaultConnectorLabel>
        <rules>
            <name>Yes_CX_Case</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Customer_Experience</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Origin</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Webform</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Web_Category_Values</targetReference>
            </connector>
            <label>Yes CX Case</label>
        </rules>
    </decisions>
    <decisions>
        <name>Does_Found_Account_match_Supplied_Case_Values</name>
        <label>Does Found Account match Supplied Case Values</label>
        <locationX>776</locationX>
        <locationY>600</locationY>
        <defaultConnector>
            <targetReference>Find_Triple_Matched_Account</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No - Values don&apos;t match</defaultConnectorLabel>
        <rules>
            <name>Yes_Values_Match</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Find_Associated_Account.DateOfBirth__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Date_of_Birth__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Find_Associated_Account.PersonEmail</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Record.SuppliedEmail</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>form_FormattedAccountPhone</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>form_FormattedSuppliedPhone</elementReference>
                </rightValue>
            </conditions>
            <label>Yes - Values Match</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_this_Web_Form_Case</name>
        <label>Is this Web Form Case</label>
        <locationX>1073</locationX>
        <locationY>276</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_WebCase</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Customer_Experience</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Origin</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Webform</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Find_Case</targetReference>
            </connector>
            <label>Yes - WebCase</label>
        </rules>
    </decisions>
    <decisions>
        <name>Was_a_Triple_match_found</name>
        <label>Was a Triple-match found</label>
        <locationX>974</locationX>
        <locationY>816</locationY>
        <defaultConnector>
            <targetReference>Clear_Account_Value</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Triple Match not Found</defaultConnectorLabel>
        <rules>
            <name>Triple_Match_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Find_Triple_Matched_Account.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Account</targetReference>
            </connector>
            <label>Triple Match Found</label>
        </rules>
    </decisions>
    <description>This Flow fires when a Customer Experience Case is created with an origin of Web Form. It maps the email that is used in the Web Form to an existing Account and associates it with that Account.</description>
    <environments>Default</environments>
    <formulas>
        <name>form_FormattedAccountPhone</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE(
  SUBSTITUTE(
    SUBSTITUTE(
      SUBSTITUTE(
        SUBSTITUTE(
          SUBSTITUTE( {!Find_Associated_Account.Phone} , &quot;(&quot;, &quot;&quot; ),
        &quot;)&quot;, &quot;&quot; ),
      &quot;-&quot;, &quot;&quot; ),
    &quot; &quot;, &quot;&quot; ),
  &quot;+&quot;, &quot;&quot; ),
&quot;.&quot;, &quot;&quot;
)</expression>
    </formulas>
    <formulas>
        <name>form_FormattedSuppliedPhone</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE(
  SUBSTITUTE(
    SUBSTITUTE(
      SUBSTITUTE(
        SUBSTITUTE(
          SUBSTITUTE( {!$Record.SuppliedPhone} , &quot;(&quot;, &quot;&quot; ),
        &quot;)&quot;, &quot;&quot; ),
      &quot;-&quot;, &quot;&quot; ),
    &quot; &quot;, &quot;&quot; ),
  &quot;+&quot;, &quot;&quot; ),
&quot;.&quot;, &quot;&quot;
)</expression>
    </formulas>
    <formulas>
        <name>TriggeringCaseID</name>
        <dataType>String</dataType>
        <expression>{!$Record.Id}</expression>
    </formulas>
    <interviewLabel>Record Trigger - Case - Assign Web Case to Account {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Case - Assign Web Case to Account</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Find_Associated_Account</name>
        <label>Find Associated Account</label>
        <locationX>776</locationX>
        <locationY>492</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Does_Found_Account_match_Supplied_Case_Values</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
