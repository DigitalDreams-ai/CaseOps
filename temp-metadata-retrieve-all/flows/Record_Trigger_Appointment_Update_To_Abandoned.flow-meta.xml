    <decisions>
        <name>Is_the_Appointment_still_in_No_Show_Sub_Status</name>
        <label>Is the Appointment still in No Show Sub Status</label>
        <locationX>578</locationX>
        <locationY>276</locationY>
        <defaultConnector>
            <targetReference>Log_Debug_Status_has_changed_no_need_to_update_to_Abandoned</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Status changed</defaultConnectorLabel>
        <rules>
            <name>Still_No_Show</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Sub_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Patient No Show</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Sub_Status_to_Abandoned</targetReference>
            </connector>
            <label>Still No Show</label>
        </rules>
    </decisions>
