    <description>When the patient account has been synced to drchrono this will check to ensure all of the patient agreements are synced to the patient&apos;s drchrono account.

Delayed 1 minute to let DML process before making API Callouts.</description>
    <environments>Default</environments>
    <formulas>
        <name>form_PA_to_sync</name>
        <dataType>String</dataType>
        <expression>&quot;Pa to Sync: &quot; +{!col_Patient_Agreement}</expression>
    </formulas>
