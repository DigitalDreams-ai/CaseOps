    <decisions>
        <description>Here we ensure that the doctor has a practice group. If they do then we can proceed if not then we need to ask for one and have them fill it in before we can proceed.</description>
        <name>Does_Account_Have_Practice_Group_Set</name>
        <label>Does Account Have Practice Group Set</label>
        <locationX>512</locationX>
        <locationY>350</locationY>
        <defaultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Log_Select_Practice_Group</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Practice Group Set</defaultConnectorLabel>
        <rules>
            <name>Practice_Group_is_Set</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId.Practice_Group__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Does_Practice_Group_Have_External_Id_Set</targetReference>
            </connector>
            <label>Practice Group is Set</label>
        </rules>
    </decisions>
    <decisions>
        <description>Even tho there is a practice group we need to verify that the external id field is filled in.</description>
        <name>Does_Practice_Group_Have_External_Id_Set</name>
        <label>Does Practice Group Have External Id Set</label>
        <locationX>50</locationX>
        <locationY>458</locationY>
        <defaultConnector>
            <targetReference>Log_Select_Practice_Group</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>External Id Is Not filled In</defaultConnectorLabel>
        <rules>
            <name>External_Id_is_Filled_In</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId.Practice_Group__r.External_Id__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Starting_Apex_Action</targetReference>
            </connector>
            <label>External Id is Filled In</label>
        </rules>
    </decisions>
