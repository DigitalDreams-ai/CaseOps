        </defaultConnector>
        <defaultConnectorLabel>Other Errors</defaultConnectorLabel>
        <rules>
            <name>In_Person_Kit_Id_Missing</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Submit_Lab_Order_Request.results.errorMessage</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Kit Id is required for In Person Lab Orders</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Error_Message_Missing_Kit_Id_for_In_Person</targetReference>
            </connector>
            <label>In Person Kit Id Missing</label>
        </rules>
    </decisions>
