<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <constants>
        <name>const_IntegrationUser_ProfileName</name>
        <dataType>String</dataType>
        <value>
            <stringValue>SFDC Integrations</stringValue>
        </value>
    </constants>
    <decisions>
        <description>Is Record Staus Completed and Running User Profile is Integration User then block the API Call</description>
        <name>Is_Record_Staus_Completed_and_Running_User_Profile_is_Integration_User</name>
        <label>Is Record Staus Completed and Running User Profile is Integration User</label>
        <locationX>374</locationX>
        <locationY>276</locationY>
        <defaultConnector>
            <targetReference>Update_Appointment</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Other Users</defaultConnectorLabel>
        <rules>
            <name>Is_Integration_User</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>const_IntegrationUser_ProfileName</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.appointment_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <label>Is Integration User ?</label>
        </rules>
    </decisions>
    <description>This will update the EHR appointment everytime that the Salesforce Appointment has been updated</description>
    <environments>Default</environments>
    <formulas>
        <name>num_MinutesSinceUpdate</name>
        <dataType>Number</dataType>
        <expression>({!$Flow.CurrentDateTime} - {!$Record.Updated_At__c}) * 1440</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>Record Trigger - Appointment - Update EHR Appointment {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Appointment - Update EHR Appointment</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>appointment_Status__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Start_Date__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>End_Date__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Provider_Account__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Appointment__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <scheduledPaths>
            <connector>
                <targetReference>Is_Record_Staus_Completed_and_Running_User_Profile_is_Integration_User</targetReference>
            </connector>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Update_Appointment</name>
        <label>Update Appointment</label>
        <locationX>506</locationX>
        <locationY>384</locationY>
        <flowName>Autolaunch_EHR_Appointment</flowName>
        <inputAssignments>
            <name>rec_Appointment</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </subflows>
</Flow>
