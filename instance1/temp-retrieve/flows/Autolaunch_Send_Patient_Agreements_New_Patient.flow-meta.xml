    <decisions>
        <description>We need to exclude all patient agreements that are not for this patients gender.</description>
        <name>Is_Patient_Agreement_Gender_Specific</name>
        <label>Is Patient Agreement Gender Specific</label>
        <locationX>688</locationX>
        <locationY>782</locationY>
        <defaultConnector>
            <targetReference>Create_Collection_of_Patient_Agreement_Configurations</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Non-Gender Specific</defaultConnectorLabel>
        <rules>
            <name>Gender_Specific_Doesn_t_Match_Account_Gender</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Through_Patient_Agreement_Configurations.Is_Gender_Specific__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Through_Patient_Agreement_Configurations.Gender__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>rec_Account.Gender__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Loop_Through_Patient_Agreement_Configurations</targetReference>
            </connector>
            <label>Gender Specific - Doesn&apos;t Match Account Gender</label>
        </rules>
        <rules>
            <name>Gender_Specific_Matches_Account_Gender</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Through_Patient_Agreement_Configurations.Is_Gender_Specific__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Through_Patient_Agreement_Configurations.Gender__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>rec_Account.Gender__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Collection_of_Patient_Agreement_Configurations</targetReference>
            </connector>
            <label>Gender Specific - Matches Account Gender</label>
        </rules>
    </decisions>
