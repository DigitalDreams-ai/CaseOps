        <defaultConnectorLabel>Not Approved</defaultConnectorLabel>
        <rules>
            <name>Approve</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rec_PatientAgreement.Patient_Agreement_Configuration__r.Auto_Approved_Upon_Receive__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Patient_Agreement_Status_Approved</targetReference>
            </connector>
            <label>Approve</label>
        </rules>
    </decisions>
