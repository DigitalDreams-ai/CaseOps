    <formulas>
        <name>form_ExpirationDate</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS({!$Flow.CurrentDate},{!rec_PatientAgreement.Patient_Agreement_Configuration__r.Number_of_Months_for_Recurrence__c})</expression>
    </formulas>
    <formulas>
