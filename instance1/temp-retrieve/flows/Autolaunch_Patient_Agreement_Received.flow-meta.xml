            </connector>
            <label>Status is Sent</label>
        </rules>
        <rules>
            <name>Status_is_Received</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rec_PatientAgreement.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Received</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Patient_Agreement_Status_Review</targetReference>
            </connector>
            <label>Status is Received</label>
        </rules>
    </decisions>
    <description>This will take a patient agreement that has been received and will set the appropriate status and create task for the team to look over the document and approve or reject if needed.</description>
