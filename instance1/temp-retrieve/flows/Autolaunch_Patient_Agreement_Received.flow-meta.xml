        <defaultConnectorLabel>Other</defaultConnectorLabel>
        <rules>
            <name>Status_is_Sent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rec_PatientAgreement.Status__c</leftValueReference>
                <operator>EqualTo</operator>
