    <description>This flow will allow the end user to see the current key and expiration and send the custom a new Key and reset the expiration date.</description>
    <environments>Default</environments>
    <formulas>
        <name>form_Key</name>
        <dataType>String</dataType>
        <expression>MID(
    CASESAFEID(RIGHT({!Get_Account.Id}, 15)) &amp;
    CASESAFEID(RIGHT({!$Organization.Id}, 15)) &amp;
    TEXT(YEAR(TODAY())) &amp; TEXT(MONTH(TODAY())) &amp; TEXT(DAY(TODAY())),
    1, 40
)</expression>
    </formulas>
    <formulas>
        <name>form_ValidThruDate</name>
        <dataType>Date</dataType>
        <expression>TODAY()+2</expression>
    </formulas>
