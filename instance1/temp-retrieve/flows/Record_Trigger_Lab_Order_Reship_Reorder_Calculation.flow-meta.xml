    <collectionProcessors>
        <description>We have to check that if we change to a new lab provider from the most recent lab provider, we must see if there are existing lab orders with the changed lab provider name.</description>
        <name>Check_if_there_was_existing_lab_orders_with_newly_lab_provider</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Check if there was existing lab orders with newly lab provider</label>
        <locationX>534</locationX>
        <locationY>1403</locationY>
        <assignNextValueToReference>currentItem_Check_if_there_was_existing_lab_orders_with_newly_lab_provider</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_All_Associated_Lab_Orders_using_Opportunity</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Check_if_there_was_existing_lab_orders_with_newly_lab_provider.Lab_Provider__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <elementReference>latestLabProviderName_c</elementReference>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Are_there_existing_records_with_the_new_lab_provider_name</targetReference>
        </connector>
    </collectionProcessors>
    <decisions>
        <description>Check from the filtered collection to see if any records were returned</description>
        <name>Are_there_existing_records_with_the_new_lab_provider_name</name>
