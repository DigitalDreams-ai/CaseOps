            </connector>
            <label>First Record</label>
        </rules>
    </decisions>
    <decisions>
        <description>We check latest created lab order&apos;s lab provider and check it against the newly created lab order lab provider to see if there was a change. Essentially Reshipment vs Reorder</description>
        <name>Was_there_a_change_in_lab_provider</name>
        <label>Was there a change in lab provider?</label>
        <locationX>732</locationX>
        <locationY>1295</locationY>
        <defaultConnector>
            <targetReference>Increment_Reshipment_Values_on_Lab_Order</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Lab_Provider_was_Changed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>latestLabProviderName_c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Lab_Provider__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_if_there_was_existing_lab_orders_with_newly_lab_provider</targetReference>
            </connector>
            <label>Lab Provider was Changed</label>
        </rules>
    </decisions>
    <description>This flow will go thru and update the Reship and Reorder counter on the Lab Order
