    <decisions>
        <description>Checks if most recent lab order from the collection of lab orders. Will use a counter variable to get the first record as the collection is already sorted.</description>
        <name>Is_this_most_recent_lab_order</name>
        <label>Is this most recent lab order?</label>
        <locationX>952</locationX>
        <locationY>911</locationY>
        <defaultConnector>
            <targetReference>Loop_for_getting_Latest_Lab_Provider</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_most_recent_lab_order</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>counterForMostRecentLabOrder</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>assignMostRecentLabOrderValues</targetReference>
            </connector>
            <label>Is most recent lab order</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check is this newly created Lab Order is the first record created with the attached opportunity</description>
        <name>Is_this_the_first_lab_order</name>
        <label>Is this the first lab order?</label>
        <locationX>391</locationX>
        <locationY>287</locationY>
        <defaultConnector>
            <targetReference>Is_it_a_Lab_Order_without_an_Opportunity</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not a first record</defaultConnectorLabel>
        <rules>
            <name>First_Record_C</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Original_Lab_Order__c</leftValueReference>
