    <start>
        <locationX>254</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Flat_Commission_Rule_is_Null</targetReference>
        </connector>
        <filterFormula>AND(
  {!$Setup.AutomationControlSettings__c.Commissions_Automations_Activated__c},
  OR(
    ISCHANGED({!$Record.Flat_Rate_Sales_Total__c}), 
    ISCHANGED({!$Record.Flat_Chargeback_Sales_Total__c}),
    ISCHANGED({!$Record.Flat_Refunded_Sales_Total__c}),
    ISCHANGED({!$Record.Tiered_Rate_Sales_Total__c}),
    ISCHANGED({!$Record.Tiered_Chargeback_Sales_Total__c}),
    ISCHANGED({!$Record.Tiered_Refunded_Sales_Total__c})
  )
)</filterFormula>
        <object>Commission_Summary__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
