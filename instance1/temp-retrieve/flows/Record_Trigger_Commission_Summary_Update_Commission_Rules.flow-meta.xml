    <decisions>
        <name>Tiered_Totals_are_Still_Within_Rule_Parameters_AND_Tiered_Rule_NOT_Null</name>
        <label>Tiered Totals are Still Within Rule Parameters AND Tiered Rule NOT Null?</label>
        <locationX>380</locationX>
        <locationY>1031</locationY>
        <defaultConnector>
            <targetReference>Get_New_Tiered_Rule</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No - Outside of Parameters</defaultConnectorLabel>
        <rules>
            <name>Yes_Still_Within_Tiered_Commission_Rule_Params</name>
            <conditionLogic>(1 AND 2 AND 3) OR (2 AND 3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Tiered_Commission_Rule__r.Maximum_Sale_Total_Value__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>form_numTieredSalesTotal</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Tiered_Commission_Rule__r.Minimum_Sale_Total_Value__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>form_numTieredSalesTotal</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Tiered_Commission_Rule__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Tiered_Commission_Rule__r.Maximum_Sale_Total_Value__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>No_Update_Still_Within_Tiered_Parameters</targetReference>
            </connector>
            <label>Yes - Still Within Tiered Commission Rule Params</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>form_numTieredSalesTotal</name>
        <dataType>Currency</dataType>
        <expression>IF( {!$Record.Tiered_Sales_Total_Final__c} &lt; 0,
0,
{!$Record.Tiered_Sales_Total_Final__c}
)</expression>
        <scale>2</scale>
    </formulas>
