    <description>Updates Opportunity.Lab_Name__c (lab vendor Account) for Approved Labs opportunities when nursing users are blocked by post-approval record lock. Runs in system context; access is limited by custom permission and permission set.</description>
    <dynamicChoiceSets>
        <name>recChoice_Lab_Accounts</name>
        <dataType>String</dataType>
        <displayField>Name</displayField>
        <filterLogic>and</filterLogic>
        <filters>
            <field>RecordTypeId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_Lab_Account_Record_Type.Id</elementReference>
            </value>
        </filters>
        <object>Account</object>
        <sortField>Name</sortField>
        <sortOrder>Asc</sortOrder>
        <valueField>Id</valueField>
    </dynamicChoiceSets>
