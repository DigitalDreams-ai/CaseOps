    <decisions>
        <name>Decision_Has_Nurse_Lab_Vendor_Permission</name>
        <label>Has nurse lab vendor permission?</label>
        <locationX>776</locationX>
        <locationY>170</locationY>
        <defaultConnector>
            <targetReference>Screen_No_Access</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Outcome_Has_Permission</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Permission.Nurse_Post_Approval_Lab_Vendor_Edit</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Lab_Account_Record_Type</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_Is_Approved_Labs_Opportunity</name>
        <label>Approved Labs opportunity?</label>
        <locationX>776</locationX>
        <locationY>890</locationY>
        <defaultConnector>
            <targetReference>Screen_Not_Target_Context</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not eligible</defaultConnectorLabel>
        <rules>
            <name>Outcome_Is_Valid</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Opportunity.RecordTypeId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_Labs_Opportunity_Record_Type.Id</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Opportunity.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Screen_Select_Lab_Vendor</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
