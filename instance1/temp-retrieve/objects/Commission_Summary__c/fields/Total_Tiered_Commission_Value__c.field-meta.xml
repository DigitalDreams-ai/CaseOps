<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Total_Tiered_Commission_Value__c</fullName>
    <formula>IF(
				Tiered_Sales_Total_Final__c = 0, 0,
				(Tiered_Sales_Total_Final__c - $Setup.AutomationControlSettings__c.Commissions_Threshold_Amount__c ) * Tiered_Commission_Rule__r.Commission_Percent__c
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Total Tiered Commission Value</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
