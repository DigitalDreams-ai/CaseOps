<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cancelled_with_No_Cancellation_Reason</fullName>
    <active>true</active>
    <description>We need to ensure that they enter a cancellation reason when they cancel an appointment.</description>
    <errorConditionFormula>AND( 
				ISPICKVAL(appointment_Status__c, &quot;Cancelled&quot;),
				ISBLANK(TEXT(appointment_cancellation_reason__c))
)</errorConditionFormula>
    <errorDisplayField>appointment_cancellation_reason__c</errorDisplayField>
    <errorMessage>Please set a cancellation reason.</errorMessage>
</ValidationRule>
