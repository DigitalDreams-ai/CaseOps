<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Credit_Card_Number_Only_Numbers</fullName>
    <active>true</active>
    <errorConditionFormula>CONTAINS( CreditCardNumber__c , &apos;-&apos;)
||
CONTAINS( CreditCardNumber__c , &apos;,&apos;)</errorConditionFormula>
    <errorDisplayField>Credit_Card_Number_Unencrypted__c</errorDisplayField>
    <errorMessage>Credit Card Number Can Not Contain Dashes Or Commas</errorMessage>
</ValidationRule>
