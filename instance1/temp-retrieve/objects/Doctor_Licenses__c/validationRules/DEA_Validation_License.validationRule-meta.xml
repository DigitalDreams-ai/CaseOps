<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>DEA_Validation_License</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(License_Type__c, &quot;DEA&quot;),
    OR(
        ISBLANK(License_Number__c)
    )
)</errorConditionFormula>
    <errorDisplayField>License_Number__c</errorDisplayField>
    <errorMessage>DEA licenses must have a license number.</errorMessage>
</ValidationRule>
