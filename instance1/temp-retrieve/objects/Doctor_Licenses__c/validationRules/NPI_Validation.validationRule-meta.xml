<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NPI_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(License_Type__c, &quot;NPI&quot;),
    NOT(REGEX(License_Number__c, &quot;^[0-9]{10}$&quot;))
)</errorConditionFormula>
    <errorDisplayField>License_Number__c</errorDisplayField>
    <errorMessage>NPI license numbers must be exactly 10 digits.</errorMessage>
</ValidationRule>
