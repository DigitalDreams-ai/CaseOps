<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ProductMustBeActive</fullName>
    <active>true</active>
    <errorConditionFormula>Product__r.IsActive = FALSE</errorConditionFormula>
    <errorDisplayField>Product__c</errorDisplayField>
    <errorMessage>The product you have selected is not Active</errorMessage>
</ValidationRule>
