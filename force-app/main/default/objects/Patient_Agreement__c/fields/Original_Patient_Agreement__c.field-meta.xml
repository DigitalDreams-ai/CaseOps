<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Original_Patient_Agreement__c</fullName>
    <deleteConstraint>SetNull</deleteConstraint>
    <description>This field will be used for when a patient agreement is rejected to know what patient agreement supersedes or when a patient agreement expires which agreement is the latest agreement.</description>
    <label>Original Patient Agreement</label>
    <lookupFilter>
        <active>true</active>
        <errorMessage>Patient Agreement must be for the same Patient</errorMessage>
        <filterItems>
            <field>Patient_Agreement__c.Patient__c</field>
            <operation>equals</operation>
            <valueField>$Source.Patient__c</valueField>
        </filterItems>
        <isOptional>false</isOptional>
    </lookupFilter>
    <referenceTo>Patient_Agreement__c</referenceTo>
    <relationshipLabel>Child Patient Agreements</relationshipLabel>
    <relationshipName>Patient_Agreements</relationshipName>
    <required>false</required>
    <trackFeedHistory>false</trackFeedHistory>
    <trackHistory>true</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Lookup</type>
</CustomField>
