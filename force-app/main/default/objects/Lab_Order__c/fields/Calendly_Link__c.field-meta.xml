<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Calendly_Link__c</fullName>
    <description>This field will display the Opportunity Owner Calendly Link field. If that is null, it will try to fetch Patient Owner Calendly link

- Used for Email Merge Field</description>
    <externalId>false</externalId>
    <formula>IF(NOT(ISBLANK(Opportunity__r.Owner.Calendly__CalendlyLink__c)), 
   Opportunity__r.Owner.Calendly__CalendlyLink__c, 
   Patient__r.Owner.Calendly__CalendlyLink__c)</formula>
    <label>Calendly Link</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
