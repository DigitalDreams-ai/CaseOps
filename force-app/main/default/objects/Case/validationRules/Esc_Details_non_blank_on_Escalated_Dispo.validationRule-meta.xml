<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Esc_Details_non_blank_on_Escalated_Dispo</fullName>
    <active>false</active>
    <description>The escalation details field must be populated when Dispo 3 is Escalated</description>
    <errorConditionFormula>AND(
    TEXT(Dispo_Level_3__c) = &quot;Escalation&quot;,
    ISBLANK( Escalation_Details__c )
)</errorConditionFormula>
    <errorDisplayField>Escalation_Details__c</errorDisplayField>
    <errorMessage>Please fill out escalation details for this case.</errorMessage>
</ValidationRule>
