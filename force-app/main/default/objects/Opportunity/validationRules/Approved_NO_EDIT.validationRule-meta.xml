<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Approved_NO_EDIT</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
ISPICKVAL(PRIORVALUE(StageName),&quot;Approved&quot;),
NOT($Profile.Id = &quot;00e0b000001nOvW&quot;),
NOT($Profile.Id = &quot;00e0b000001iU5h&quot;),
NOT($Profile.Id = &quot;00e5a000001OuCR&quot;),
NOT($Profile.Id = &quot;00e0b000001nOvl&quot;)
)</errorConditionFormula>
    <errorMessage>You Can Not Edit This Opportunity Because Has Been Approved</errorMessage>
</ValidationRule>
