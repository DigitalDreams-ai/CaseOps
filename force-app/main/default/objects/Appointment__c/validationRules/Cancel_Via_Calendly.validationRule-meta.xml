<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cancel_Via_Calendly</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
				ISPICKVAL(appointment_Status__c, &quot;Cancelled&quot;),
    $Profile.Id != &quot;00e0b000001iU5h&quot;,
    NOT(ISNULL( Calendly_UUID__c ))
)</errorConditionFormula>
    <errorMessage>Please Cancel Via Calendlty</errorMessage>
</ValidationRule>
