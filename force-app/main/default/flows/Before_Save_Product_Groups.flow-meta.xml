    <formulas>
        <name>formulaBroken</name>
        <dataType>Number</dataType>
        <expression>IF(TEXT({!Loop_Inventory_Management.Movement__c})=&quot;Broken&quot;,{!Loop_Inventory_Management.Quantity__c},0)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
