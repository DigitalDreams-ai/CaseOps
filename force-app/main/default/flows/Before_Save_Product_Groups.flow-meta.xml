        <expression>IF(TEXT({!Loop_Inventory_Management.Movement__c})=&quot;Owed&quot;,{!Loop_Inventory_Management.Quantity__c},0)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>formulaOwedFinal</name>
        <dataType>Number</dataType>
        <expression>{!sumOwed} - {!sumClaimed}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>formulaRestocked</name>
        <dataType>Number</dataType>
        <expression>IF(TEXT({!Loop_Inventory_Management.Movement__c})=&quot;Restocked&quot;,{!Loop_Inventory_Management.Quantity__c},0)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>formulaTotalAvailable</name>
        <dataType>Number</dataType>
        <expression>{!sumRestocked} - {!sumClaimed} - {!sumBroken}</expression>
        <scale>0</scale>
    </formulas>
