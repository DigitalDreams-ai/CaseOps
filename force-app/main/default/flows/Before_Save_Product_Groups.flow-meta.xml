    </formulas>
    <formulas>
        <name>formulaInventoryBalance</name>
        <dataType>Number</dataType>
        <expression>{!formulaTotalAvailable} - {!formulaOwedFinal}

/*** Original Formula: sumRestocked - sumOwed - sumClaimed - sumBroken ***/</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>formulaInventoryBalanceWorstCase</name>
        <dataType>Number</dataType>
