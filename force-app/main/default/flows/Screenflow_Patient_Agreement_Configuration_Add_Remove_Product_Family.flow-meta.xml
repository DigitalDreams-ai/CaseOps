    <formulas>
        <name>txt_ButtonPressed</name>
        <dataType>String</dataType>
        <expression>IF(
    {!txt_QuickActionName} = &quot;Patient_Agreement_Configuration__c.Add_Product_Family&quot;,
    &quot;Add Product Family&quot;,
    &quot;Remove Product Family&quot;
)</expression>
    </formulas>
    <formulas>
        <name>txt_RemoveSelectedFamily</name>
        <dataType>String</dataType>
        <expression>IF(
    CONTAINS({!txt_CurrentlyProductFamilies}, {!txt_SelectedPicklistValueFamily} &amp; &quot;;&quot;),
    SUBSTITUTE({!txt_CurrentlyProductFamilies}, {!txt_SelectedPicklistValueFamily} &amp; &quot;;&quot;, &quot;&quot;),
    SUBSTITUTE({!txt_CurrentlyProductFamilies}, {!txt_SelectedPicklistValueFamily}, &quot;&quot;)
)</expression>
    </formulas>
    <formulas>
        <name>txt_RemoveSelectedSubFamily</name>
        <dataType>String</dataType>
        <expression>IF(
    NOT(ISBLANK({!txt_SelectedPicklistValueSubFamily})),
    IF(
        CONTAINS({!txt_CurrentlyProductSubFamilies}, {!txt_SelectedPicklistValueSubFamily} &amp; &quot;;&quot;),
        SUBSTITUTE({!txt_CurrentlyProductSubFamilies}, {!txt_SelectedPicklistValueSubFamily} &amp; &quot;;&quot;, &quot;&quot;),
        SUBSTITUTE({!txt_CurrentlyProductSubFamilies}, {!txt_SelectedPicklistValueSubFamily}, &quot;&quot;)
    ),
    {!txt_CurrentlyProductSubFamilies}
)</expression>
    </formulas>
