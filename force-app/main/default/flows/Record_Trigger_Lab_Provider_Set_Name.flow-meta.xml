<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Set_Lab_Provider_Name</name>
        <label>Set Lab Provider Name</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <assignmentItems>
            <assignToReference>$Record.Name</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>form_RecordName</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <description>This will auto set the name based on the Lab and the Opportunity Transaction Type</description>
    <environments>Default</environments>
    <formulas>
        <name>form_RecordName</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Record.Lab__c}) + &quot; - &quot; + TEXT({!$Record.Opportunity_Transaction_Source_Multi__c})</expression>
    </formulas>
    <interviewLabel>Record Trigger - Lab Provider Set Name {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Lab Provider Set Name</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_Lab_Provider_Name</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Lab__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Opportunity_Transaction_Source_Multi__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Lab_Provider__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>InvalidDraft</status>
</Flow>
