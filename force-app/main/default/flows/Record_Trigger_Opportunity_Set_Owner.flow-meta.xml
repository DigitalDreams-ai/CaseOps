    <start>
        <locationX>584</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Log_Flow_Entry</targetReference>
        </connector>
        <filterFormula>AND(
	OR(	TEXT({!$Record.Transaction_Source__c})	=	&apos;POS&apos;,
		TEXT({!$Record.Transaction_Source__c})	=	&apos;Store&apos;,
		TEXT({!$Record.Transaction_Source__c})	=	&apos;Affiliate&apos;
	),OR(
		AND(
			{!$Record__Prior.Opportunity_Traffic_Signal__c}	=	&apos;Employee Account Set&apos;,
			NOT({!$Record.Opportunity_Traffic_Signal__c}	=	&apos;Employee Account Set&apos;)
		),AND(
			{!$Record__Prior.Opportunity_Traffic_Signal__c}	=	&apos;Employee Account Not Set&apos;,
			NOT({!$Record.Opportunity_Traffic_Signal__c}	=	&apos;Employee Account Not Set&apos;)
		)
	)
)</filterFormula>
