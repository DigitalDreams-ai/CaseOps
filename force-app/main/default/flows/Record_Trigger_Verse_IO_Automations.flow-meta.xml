    <decisions>
        <name>Object_Defined_External_Id</name>
        <label>Object Defined - External Id</label>
        <locationX>594</locationX>
        <locationY>408</locationY>
        <defaultConnectorLabel>Not a Lead Record</defaultConnectorLabel>
        <rules>
            <name>New_Record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.External_Id__c</leftValueReference>
                <operator>IsNull</operator>
