    <description>This flow will run when a new Verse.IO record is created and will update the lead and save the message/notes to a task record associated with the lead record. If no lead is found then we do not create a task.</description>
    <environments>Default</environments>
    <formulas>
        <name>formLinkToRecord</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Enterprise_Server_URL_550}, FIND( &apos;/services&apos;, {!$Api.Enterprise_Server_URL_550})) &amp; {!$Record.Id}</expression>
    </formulas>
    <interviewLabel>Record Trigger - Verse.IO - Create Activity and Update Lead Status {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Verse.IO - Create Activity and Update Lead Status</label>
    <loops>
        <description>We will only grab the first lead and then update the verse io record with that id</description>
        <name>Loop_Through_Leads</name>
        <label>Loop Through Leads</label>
        <locationX>486</locationX>
        <locationY>2712</locationY>
        <collectionReference>Search_for_a_Lead.leadIds</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Set_the_Lead_Record_Id_Existing</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Update_Verse_IO_Lead</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
