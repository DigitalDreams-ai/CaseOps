<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>56.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Create_New_Campaign</name>
        <label>Create New Campaign</label>
        <locationX>314</locationX>
        <locationY>755</locationY>
        <assignmentItems>
            <assignToReference>recNewCampaign.Affiliate_Code__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Campaign_Code__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>recNewCampaign.StartDate</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>recNewCampaign.Type</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Influencer</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>recNewCampaign.Description</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Automatically Created from Salesforce Automations</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>recNewCampaign.Name</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Campaign_Code__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>recNewCampaign.Status</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>In Progress</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>recNewCampaign.IsActive</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Create_Campaign</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Campaign_on_Oppty</name>
        <label>Set Campaign on Oppty</label>
        <locationX>50</locationX>
        <locationY>755</locationY>
        <assignmentItems>
            <assignToReference>rec_UpdatedOpportunity.CampaignId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Find_Matching_Campaign.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Opportunity</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Campaign_on_Oppty_New_Campaign</name>
        <label>Set Campaign on Oppty - New Campaign</label>
        <locationX>314</locationX>
        <locationY>971</locationY>
        <assignmentItems>
            <assignToReference>rec_UpdatedOpportunity.CampaignId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>recNewCampaign.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Opportunity</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Default_Values_Updated_Opportunity</name>
        <label>Set Default Values - Updated Opportunity</label>
        <locationX>380</locationX>
        <locationY>323</locationY>
        <assignmentItems>
            <assignToReference>rec_UpdatedOpportunity.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Is_Campaign_Code_Filled_In</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Campaign_Found</name>
        <label>Campaign Found</label>
        <locationX>182</locationX>
        <locationY>647</locationY>
        <defaultConnector>
            <targetReference>Create_New_Campaign</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Campaign Found</defaultConnectorLabel>
        <rules>
            <name>Campaign_Found_Decision</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Find_Matching_Campaign</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Campaign_on_Oppty</targetReference>
            </connector>
            <label>Campaign Found</label>
        </rules>
    </decisions>
    <decisions>
        <description>If the campaign code is filled in, look at the campaign object and see if we can find a campaign</description>
        <name>Is_Campaign_Code_Filled_In</name>
        <label>Is Campaign Code Filled In</label>
        <locationX>380</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Update_Opportunity</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Campaign Code</defaultConnectorLabel>
        <rules>
            <name>Campaign_Code_Filled_In</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Campaign_Code__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Find_Matching_Campaign</targetReference>
            </connector>
            <label>Campaign Code Filled In</label>
        </rules>
    </decisions>
    <description>This automation will take the Campaign code if it is filled in it will look at the campaigns and find one that matches that and link that record.</description>
    <environments>Default</environments>
    <interviewLabel>Record Trigger - Opportunity - Link Affiliate Code to Campaign {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Opportunity - Link Campaign</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Campaign</name>
        <label>Create Campaign</label>
        <locationX>314</locationX>
        <locationY>863</locationY>
        <connector>
            <targetReference>Set_Campaign_on_Oppty_New_Campaign</targetReference>
        </connector>
        <inputReference>recNewCampaign</inputReference>
    </recordCreates>
    <recordLookups>
        <name>Find_Matching_Campaign</name>
        <label>Find Matching Campaign</label>
        <locationX>182</locationX>
        <locationY>539</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Campaign_Found</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Affiliate_Code__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Campaign_Code__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Campaign</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Opportunity</name>
        <label>Update Opportunity</label>
        <locationX>380</locationX>
        <locationY>1247</locationY>
        <inputReference>rec_UpdatedOpportunity</inputReference>
    </recordUpdates>
    <start>
        <locationX>254</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_Default_Values_Updated_Opportunity</targetReference>
        </connector>
        <filterFormula>IF( 
AND(
OR(ISNEW(), ISCHANGED({!$Record.Campaign_Code__c}), ISCHANGED({!$Record.Affiliate_Code__c})),
OR(
AND(NOT(ISNULL({!$Record.Campaign_Code__c})), NOT(ISBLANK({!$Record.Campaign_Code__c}))),
AND(NOT(ISNULL({!$Record.Affiliate_Code__c})), NOT(ISBLANK({!$Record.Affiliate_Code__c})))
))
, TRUE, FALSE )</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <triggerOrder>100</triggerOrder>
    <variables>
        <description>A record to hold the updated values that this automation has done. This will make sure users won&apos;t get an error on a field they don&apos;t have access to.</description>
        <name>rec_UpdatedOpportunity</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Opportunity</objectType>
    </variables>
    <variables>
        <name>recAccount</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Account</objectType>
    </variables>
    <variables>
        <name>recNewCampaign</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Campaign</objectType>
    </variables>
    <variables>
        <name>recNewCampaignInfluencer</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>CampaignInfluenceModel</objectType>
    </variables>
</Flow>
