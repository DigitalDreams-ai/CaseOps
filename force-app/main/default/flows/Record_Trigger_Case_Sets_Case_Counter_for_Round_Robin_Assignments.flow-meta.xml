    </assignments>
    <constants>
        <name>const_numMaxUserTier1</name>
        <dataType>Number</dataType>
        <value>
            <numberValue>14.0</numberValue>
        </value>
    </constants>
    <constants>
        <name>const_numMaxUserTier2</name>
        <dataType>Number</dataType>
        <value>
            <numberValue>7.0</numberValue>
        </value>
    </constants>
    <decisions>
        <description>We are checking to see if the case has been escalated or not. If the case has been escalated we will assign the case to Tier 2 and if the case hasn&apos;t been escalated we will assign the case to Tier 1.</description>
        <name>Is_this_Case_Escalated</name>
        <label>Is this Case Escalated?</label>
        <locationX>182</locationX>
        <locationY>287</locationY>
        <defaultConnector>
            <targetReference>Get_Initial_Customer_Experience_Tier_1</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Case is NOT Escalated</defaultConnectorLabel>
        <rules>
            <name>Case_is_Escalated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.IsEscalated</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Initial_Customer_Experience_Tier_2</targetReference>
            </connector>
            <label>Case is Escalated</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>form_CaseNumberTier1</name>
        <dataType>Number</dataType>
        <expression>IF(
    ISBLANK({!Get_Initial_Customer_Experience_Tier_1.Tier_1_Case_Counter__c}),
    1,
    IF(
        {!Get_Initial_Customer_Experience_Tier_1.Tier_1_Case_Counter__c} &lt; {!const_numMaxUserTier1}, 
        {!Get_Initial_Customer_Experience_Tier_1.Tier_1_Case_Counter__c} + 1, 
        1
    )
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>form_CaseNumberTier2</name>
        <dataType>Number</dataType>
        <expression>IF(
    ISBLANK({!Get_Initial_Customer_Experience_Tier_2.Tier_2_Case_Counter__c}),
    1,
    IF(
        {!Get_Initial_Customer_Experience_Tier_2.Tier_2_Case_Counter__c} &lt; {!const_numMaxUserTier2}, 
        {!Get_Initial_Customer_Experience_Tier_2.Tier_2_Case_Counter__c} + 1, 
        1
    )
)</expression>
        <scale>0</scale>
    </formulas>
