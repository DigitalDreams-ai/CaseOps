<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Record_Tier_1</name>
        <label>Assign Record Tier 1</label>
        <locationX>314</locationX>
        <locationY>503</locationY>
        <assignmentItems>
            <assignToReference>$Record.Tier_1_Case_Counter__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>form_CaseNumberTier1</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Assign_Record_Tier_2</name>
        <label>Assign Record Tier 2</label>
        <locationX>50</locationX>
        <locationY>503</locationY>
        <assignmentItems>
            <assignToReference>$Record.Tier_2_Case_Counter__c</assignToReference>
