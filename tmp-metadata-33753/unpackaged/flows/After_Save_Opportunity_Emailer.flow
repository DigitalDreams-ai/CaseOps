    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Set_Email_Template_Non_Subscription</name>
        <label>Set Email Template - Non Subscription</label>
        <locationX>418</locationX>
        <locationY>1032</locationY>
        <assignmentItems>
            <assignToReference>txtEmailTemplate</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Email_Template_Approved_Medication.txt_EmailTemplate</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Is_Email_Template_Filled_In</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Email_Variables</name>
        <label>Set Email Variables</label>
        <locationX>506</locationX>
        <locationY>492</locationY>
        <assignmentItems>
            <assignToReference>txtToAddress</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Patient_Email__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txtOpptyId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txtOrgWideEmail</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Org_Wide_Email_for_Operations.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txtContactId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Account.PersonContactId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txtSenderDisplayName</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Org_Wide_Email_for_Operations.DisplayName</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_Products_on_Opportunity_Medication</targetReference>
        </connector>
    </assignments>
    <constants>
        <name>const_FlowApiName</name>
        <dataType>String</dataType>
        <value>
            <stringValue>After_Save_Opportunity_Emailer</stringValue>
        </value>
    </constants>
    <decisions>
        <description>We check if the email has been bounced, if the email is bounced we can&apos;t send an email</description>
        <name>Did_Email_Bounce</name>
        <label>Did Email Bounce?</label>
        <locationX>506</locationX>
        <locationY>1416</locationY>
        <defaultConnector>
            <targetReference>Send_Email_Core</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Email is Not Bounced</defaultConnectorLabel>
        <rules>
            <name>Email_Bounced</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.PersonEmailBouncedDate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Info_Email_Address_Marked_As_Bounced</targetReference>
            </connector>
            <label>Email Bounced</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Email_Template_Filled_In</name>
        <label>Is Email Template Filled In</label>
        <locationX>506</locationX>
        <locationY>1308</locationY>
        <defaultConnector>
            <targetReference>Copy_3_of_Log_Info_To_Email_Not_Set</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Continue</defaultConnectorLabel>
        <rules>
            <name>To_Email_Address_is_Null</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Patient_Email__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_2_of_Log_info_startflow</targetReference>
            </connector>
            <label>To Email Address is Null</label>
        </rules>
        <rules>
            <name>Email_Template_NOT_Null</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>txtEmailTemplate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Patient_Email__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Did_Email_Bounce</targetReference>
            </connector>
            <label>Email Template NOT Null</label>
        </rules>
    </decisions>
    <decisions>
        <description>If this is a serviceable item; their will be a lab order created and we don&apos;t need to send confirmation email as this will be done i nthe Lab Order - Emailer flow.</description>
        <name>Is_Servicable_Item</name>
        <label>Is Servicable Item</label>
        <locationX>506</locationX>
        <locationY>708</locationY>
        <defaultConnector>
            <targetReference>Is_Email_Template_Filled_In</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Servvicable Items</defaultConnectorLabel>
        <rules>
            <name>Non_Servicable_Item_New</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Products_on_Opportunity_Medication.txt_ServiceProvided</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Transaction_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Shopify</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Is_Supplement_Checked</targetReference>
            </connector>
            <label>Non-Servicable Item - New</label>
        </rules>
        <rules>
            <name>Non_Servicable_Item_Updated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Products_on_Opportunity_Medication.txt_ServiceProvided</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_Supplement_Checked</targetReference>
            </connector>
            <label>Non-Servicable Item - Updated</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Supplement_Checked</name>
        <label>Is Supplement Checked</label>
        <locationX>550</locationX>
        <locationY>816</locationY>
        <defaultConnector>
            <targetReference>Is_Email_Template_Filled_In</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Non Supplement</defaultConnectorLabel>
        <rules>
            <name>IsSupplement_Checked</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.IsSupplement__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Email_Template_Approved_Medication</targetReference>
            </connector>
            <label>IsSupplement Checked</label>
        </rules>
    </decisions>
    <description>This flow will handle all of the opportunity emails that need to be sent out either internally or externally</description>
    <environments>Default</environments>
    <formulas>
        <description>This will get the correct email template for the specific lab.</description>
        <name>form_KitSentEmailTemplate</name>
        <dataType>String</dataType>
        <expression>IF( ISPICKVAL({!$Record.Lab_Provider__r.Lab__c}, &quot;EmpowerDX&quot;), &quot;GT_Virtual_Kit_is_Sent_NEW_1707933694350&quot;,
&quot;GT_Virtual_Kit_is_Sent_NEW_CSS_ASC_1708456345676&quot;)</expression>
    </formulas>
    <formulas>
        <name>txtRecordLink</name>
        <dataType>String</dataType>
        <expression>LEFT( $Api.Partner_Server_URL_280 , FIND( &apos;/services/&apos;, $Api.Partner_Server_URL_280)) &amp; {!$Record.Id}</expression>
    </formulas>
    <interviewLabel>After Save: Opportunity {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Opportunity - Emailer</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Org_Wide_Email_for_Operations</name>
        <label>Get Org Wide Email for Operations</label>
        <locationX>506</locationX>
        <locationY>384</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Set_Email_Variables</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Address</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>no-reply@10xhealthsystem.com</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>OrgWideEmailAddress</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>AND(
    {!$Record.RecordType.DeveloperName} = &apos;Medication_Opportunity_Record_Type&apos;,
    ISPICKVAL({!$Record.StageName}, &apos;Approved&apos;)
)</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <scheduledPaths>
            <connector>
                <targetReference>Log_info_startflow</targetReference>
            </connector>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Get_Email_Template_Approved_Medication</name>
        <label>Get Email Template - Approved - Medication</label>
        <locationX>418</locationX>
        <locationY>924</locationY>
        <connector>
            <targetReference>Set_Email_Template_Non_Subscription</targetReference>
        </connector>
        <flowName>Autolaunch_Opportunity_Approved_Confirmation_Email_Medication</flowName>
        <inputAssignments>
            <name>bool_isSubscription</name>
            <value>
                <elementReference>$Record.Subscription__c</elementReference>
            </value>
        </inputAssignments>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </subflows>
    <subflows>
        <name>Get_Products_on_Opportunity_Medication</name>
        <label>Get Products on Opportunity - Medication</label>
        <locationX>506</locationX>
        <locationY>600</locationY>
        <connector>
            <targetReference>Is_Servicable_Item</targetReference>
        </connector>
        <flowName>Autolaunch_Lab_Order_Create_Collection_of_Serviceable_Items_and_Their_Lab_SKU_s</flowName>
        <inputAssignments>
            <name>bool_Validate</name>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>rec_Opportunity</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </subflows>
    <textTemplates>
        <name>txt_ErrorMessage_EmailBounced</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Error: Email to patient not delivered successfully!

Recipient: {!$Record.Patient_Email__c}
Reason: Email bounce
Bounce reason: {!$Record.Account.PersonEmailBouncedReason}

Email template not sent:
{!txtEmailTemplate}</text>
    </textTemplates>
    <textTemplates>
        <name>txtErrorNoPatientEmail</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;On {!$Record.Name} there was no patient email, so the email that was supposed to be sent was not sent. &lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;{{ After Save: Opporutnity Emailer }}&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <description>When the first tracking number is filled in and stage = &apos;Kit Sent&apos; this internal email body will be sent</description>
        <name>txtKitSent_GT_Internal</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong style=&quot;font-size: 18px;&quot;&gt;INTERNAL NOTIFICATION:&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The Genetic Test Kit for the opportunity for the account {!$Record.Account.Name} has been shipped. Please click the link below to track the package:&lt;/p&gt;&lt;p&gt;&lt;a href=&quot;{!$Record.First_Tracking_URL__c}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(0, 58, 247); background-color: rgb(255, 255, 255);&quot;&gt;{!$Record.First_Tracking_URL__c}&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;To open this opportunity in Salesforce, please click below&lt;/p&gt;&lt;p&gt;&lt;a href=&quot;{!txtRecordLink}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(0, 58, 247);&quot;&gt;{!txtRecordLink}&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Regards,&lt;/p&gt;&lt;p&gt;10X Health&lt;/p&gt;&lt;p&gt;Main: 305.682.1818&lt;/p&gt;&lt;p&gt;Fax: 786.598.8612&lt;/p&gt;&lt;p&gt;10xhealthsystem.com&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>txtStageApproved_GT_Internal</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
