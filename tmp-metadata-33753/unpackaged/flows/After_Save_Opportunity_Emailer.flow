    <actionCalls>
        <name>Send_Email_Core</name>
        <label>Send Email - Core</label>
        <locationX>638</locationX>
        <locationY>1524</locationY>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <connector>
            <targetReference>Log_Info_Confirmation_Email_Sent_Successfully</targetReference>
        </connector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>senderType</name>
