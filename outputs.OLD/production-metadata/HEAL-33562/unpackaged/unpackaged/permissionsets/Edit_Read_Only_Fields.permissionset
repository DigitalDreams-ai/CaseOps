<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>This permission set grants permission to edit fields that are read only per page layout specifications. This will grant access to many fields and so care should be taken when assigning it.</description>
    <fieldPermissions>
        <editable>true</editable>
        <field>OrderItem.Notes__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Edit Read Only Fields</label>
    <userPermissions>
        <enabled>true</enabled>
        <name>EditReadonlyFields</name>
    </userPermissions>
</PermissionSet>
