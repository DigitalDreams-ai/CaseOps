        &quot;005Rh00000121HB&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Brian Del Prado */
        &quot;005Rh000000Xn8P&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Mo Nizami */
        &quot;0055a00000AVTNV&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Chris Scott */
        &quot;0055a0000093Vuw&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Eli Mamann */
        &quot;0055a000009fnGH&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Celena Clark */
        &quot;0050b000004Xbuk&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Hamilton Rosenblatt */
        &quot;005Rh00000196gj&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Nyah Valera */
        &quot;005Rh0000025MtD&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Maria Daniela Maldonado */
        &quot;0055a000009fnJ6&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Devin DelValle */
        &quot;0055a00000AVMbB&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Gabriel Sole */
        &quot;0055a000009fn8S&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Heidi Rubio */
        &quot;0055a00000AVTdE&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Joseph White */
        &quot;0055a000009fmbx&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Julie Carda-Coleman */
        &quot;0055a000007fkiZ&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Marco Leal */
        &quot;005Rh000000eemj&quot;, 3000 - Used_Employee_Credit_YTD__c, /* Natasha Torres */
