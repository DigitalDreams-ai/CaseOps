    <fields>
        <fullName>BMI_Status__c</fullName>
        <externalId>false</externalId>
        <formula>IF(
    Age__c &lt; 18,
    /* For Minors */
    IF(
        ISPICKVAL(Gender__c, &apos;Male&apos;),
        CASE(Age__c,
            17, IF(BMI__c &gt; 34, &apos;Over&apos;, IF(BMI__c &lt; 18, &apos;Under&apos;, &apos;Normal&apos;)),
            16, IF(BMI__c &gt; 32, &apos;Over&apos;, IF(BMI__c &lt; 17, &apos;Under&apos;, &apos;Normal&apos;)),
            15, IF(BMI__c &gt; 31, &apos;Over&apos;, IF(BMI__c &lt; 16, &apos;Under&apos;, &apos;Normal&apos;)),
            14, IF(BMI__c &gt; 30, &apos;Over&apos;, IF(BMI__c &lt; 16, &apos;Under&apos;, &apos;Normal&apos;)),
            13, IF(BMI__c &gt; 29, &apos;Over&apos;, IF(BMI__c &lt; 15, &apos;Under&apos;, &apos;Normal&apos;)),
            12, IF(BMI__c &gt; 29, &apos;Over&apos;, IF(BMI__c &lt; 15, &apos;Under&apos;, &apos;Normal&apos;)),
            11, IF(BMI__c &gt; 27, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            10, IF(BMI__c &gt; 26, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            9, IF(BMI__c &gt; 25, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            8, IF(BMI__c &gt; 23, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            7, IF(BMI__c &gt; 22, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            6, IF(BMI__c &gt; 22, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            5, IF(BMI__c &gt; 21, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            4, IF(BMI__c &gt; 21, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            3, IF(BMI__c &gt; 22, &apos;Over&apos;, IF(BMI__c &lt; 15, &apos;Under&apos;, &apos;Normal&apos;)),
            2, IF(BMI__c &gt; 23, &apos;Over&apos;, IF(BMI__c &lt; 15, &apos;Under&apos;, &apos;Normal&apos;)),
            &apos;Age Out of Range&apos;
        ),
        /* Female Minor */
        CASE(Age__c,
            17, IF(BMI__c &gt; 36, &apos;Over&apos;, IF(BMI__c &lt; 17, &apos;Under&apos;, &apos;Normal&apos;)),
            16, IF(BMI__c &gt; 35, &apos;Over&apos;, IF(BMI__c &lt; 17, &apos;Under&apos;, &apos;Normal&apos;)),
            15, IF(BMI__c &gt; 34, &apos;Over&apos;, IF(BMI__c &lt; 17, &apos;Under&apos;, &apos;Normal&apos;)),
            14, IF(BMI__c &gt; 32, &apos;Over&apos;, IF(BMI__c &lt; 17, &apos;Under&apos;, &apos;Normal&apos;)),
            13, IF(BMI__c &gt; 31, &apos;Over&apos;, IF(BMI__c &lt; 16, &apos;Under&apos;, &apos;Normal&apos;)),
            12, IF(BMI__c &gt; 30, &apos;Over&apos;, IF(BMI__c &lt; 15, &apos;Under&apos;, &apos;Normal&apos;)),
            11, IF(BMI__c &gt; 29, &apos;Over&apos;, IF(BMI__c &lt; 15, &apos;Under&apos;, &apos;Normal&apos;)),
            10, IF(BMI__c &gt; 27, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            9, IF(BMI__c &gt; 26, &apos;Over&apos;, IF(BMI__c &lt; 13, &apos;Under&apos;, &apos;Normal&apos;)),
            8, IF(BMI__c &gt; 25, &apos;Over&apos;, IF(BMI__c &lt; 13, &apos;Under&apos;, &apos;Normal&apos;)),
            7, IF(BMI__c &gt; 24, &apos;Over&apos;, IF(BMI__c &lt; 13, &apos;Under&apos;, &apos;Normal&apos;)),
            6, IF(BMI__c &gt; 23, &apos;Over&apos;, IF(BMI__c &lt; 13, &apos;Under&apos;, &apos;Normal&apos;)),
            5, IF(BMI__c &gt; 22, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            4, IF(BMI__c &gt; 22, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            3, IF(BMI__c &gt; 22, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            2, IF(BMI__c &gt; 23, &apos;Over&apos;, IF(BMI__c &lt; 14, &apos;Under&apos;, &apos;Normal&apos;)),
            &apos;Age Out of Range&apos;
        )
    ),
    /* For Adults */
    IF(
        BMI__c &gt; 40, 
        &apos;Over&apos;,
        IF(
            BMI__c &lt; 18.4, 
            &apos;Under&apos;,
            &apos;Normal&apos;
        )
    )

) + &quot; Range&quot;</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>BMI Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>BMI__c</fullName>
        <externalId>false</externalId>
        <formula>(Weight__c / (Height__c * Height__c)) * 703</formula>
