        <fullName>Wellvi_DEA_Number__c</fullName>
        <externalId>false</externalId>
        <formula>LEFT(
    TRIM(DEANumber__c),
    IF(
        CONTAINS(TRIM(DEANumber__c), &quot; &quot;),
        FIND(&quot; &quot;, TRIM(DEANumber__c)) - 1,
        LEN(TRIM(DEANumber__c))
    )
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Wellvi DEA Number</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Wellvi_Id__c</fullName>
        <caseSensitive>false</caseSensitive>
        <encryptionScheme>None</encryptionScheme>
        <externalId>true</externalId>
