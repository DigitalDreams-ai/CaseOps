    <sharingModel>Private</sharingModel>
    <validationRules>
        <fullName>AVA_SFCLOUD__Validate_AvaTax_Exemption_Customer_ID</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
  NOT(ISNEW()),
  ISCHANGED(AVA_SFCLOUD__AvaTax_Exemption_Customer_ID__c),

  NOT(
    AND(
      ISCHANGED(AVA_SFCLOUD__Customer_Id_Edit_One_Time__c),
      NOT(PRIORVALUE(AVA_SFCLOUD__Customer_Id_Edit_One_Time__c)),
      AVA_SFCLOUD__Customer_Id_Edit_One_Time__c
    )
  ),

  IF(
    LEN(AVA_SFCLOUD__AvaTax_Exemption_Customer_ID__c) &gt; 0,
    OR(
      LEN(AVA_SFCLOUD__AvaTax_Exemption_Customer_ID__c) &lt;&gt; 18,
      CASESAFEID(Id) &lt;&gt; AVA_SFCLOUD__AvaTax_Exemption_Customer_ID__c
    ),
    FALSE
  )
)</errorConditionFormula>
        <errorDisplayField>AVA_SFCLOUD__AvaTax_Exemption_Customer_ID__c</errorDisplayField>
        <errorMessage>Please do not edit this field value</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Account_Status_No_Edit</fullName>
        <active>true</active>
        <description>This VR will prevent users from making edits to an Account if the Account Status is set to Suspended or Cancelled.
Roles ID = System Administrator / HG System Administrator</description>
        <errorConditionFormula>AND(
    $UserRole.Id != &apos;00E5a000001BBHR&apos;,
    $UserRole.Id != &apos;00e5a000001OuCR&apos;,
    OR(
        ISPICKVAL(PRIORVALUE(Account_Status__c), &apos;Suspended&apos;) ,
        ISPICKVAL(PRIORVALUE(Account_Status__c), &apos;Cancelled&apos;) 
    ),
    ISPICKVAL(Account_Status__c, &apos;Cancelled&apos;),
    ISPICKVAL(Account_Status__c, &apos;Suspended&apos;)
)</errorConditionFormula>
        <errorMessage>You are not allowed to make changes to this Account because it is Suspended or Cancelled. Please create a Helpdesk ticket to reinstate this Account.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Billing_City_Validation_Rule</fullName>
        <active>false</active>
        <description>Operations, New Operations
System Administrator, HG Sys Admin
SFDC Integrations</description>
        <errorConditionFormula>AND(
    ISBLANK(BillingCity),
OR(NOT($Profile.Id = &quot;00e0b000001nOvW&quot;),NOT($Profile.Id = &quot;00e5a0000018d9a&quot;)),
OR(NOT($Profile.Id = &quot;00e0b000001iU5h&quot;),NOT($Profile.Id = &quot;00e5a000001OuCRAA0&quot;)),
OR(NOT($Profile.Id = &quot;00e5a000001Gfuk&quot;))	
)</errorConditionFormula>
        <errorDisplayField>BillingCity</errorDisplayField>
        <errorMessage>Billing City Is Required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Billing_Country_Required</fullName>
        <active>false</active>
        <description>This VR will ensure Billing Country is required on Accounts

Operations, New Operations
System Administrator, HG Sys Admin
SFDC Integrations</description>
        <errorConditionFormula>AND(
ISBLANK( BillingCountry),
OR(NOT($Profile.Id = &quot;00e0b000001nOvW&quot;),NOT($Profile.Id = &quot;00e5a0000018d9a&quot;)),
OR(NOT($Profile.Id = &quot;00e0b000001iU5h&quot;),NOT($Profile.Id = &quot;00e5a000001OuCRAA0&quot;)),
OR(NOT($Profile.Id = &quot;00e5a000001Gfuk&quot;))	
)</errorConditionFormula>
        <errorMessage>Billing Country Is Required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Billing_State_Validation_Rule</fullName>
        <active>false</active>
        <description>Operations, New Operations
System Administrator, HG Sys Admin
SFDC Integrations</description>
        <errorConditionFormula>AND(
					OR(
										BillingCountry &lt;&gt; &apos;US&apos;,
										BillingCountry &lt;&gt; &apos;USA&apos;,
										BillingCountry &lt;&gt; &apos;United States&apos;
					),
    ISBLANK(BillingState),
OR(NOT($Profile.Id = &quot;00e0b000001nOvW&quot;),NOT($Profile.Id = &quot;00e5a0000018d9a&quot;)),
OR(NOT($Profile.Id = &quot;00e0b000001iU5h&quot;),NOT($Profile.Id = &quot;00e5a000001OuCRAA0&quot;)),
OR(NOT($Profile.Id = &quot;00e5a000001Gfuk&quot;))
)</errorConditionFormula>
        <errorDisplayField>BillingState</errorDisplayField>
        <errorMessage>Billing State Is Required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Billing_Street_Validation_Rule</fullName>
        <active>false</active>
        <description>Operations, New Operations
System Administrator, HG Sys Admin
SFDC Integrations</description>
        <errorConditionFormula>AND(
    ISBLANK(BillingStreet),
OR(NOT($Profile.Id = &quot;00e0b000001nOvW&quot;),NOT($Profile.Id = &quot;00e5a0000018d9a&quot;)),
OR(NOT($Profile.Id = &quot;00e0b000001iU5h&quot;),NOT($Profile.Id = &quot;00e5a000001OuCRAA0&quot;)),
OR(NOT($Profile.Id = &quot;00e5a000001Gfuk&quot;))
)</errorConditionFormula>
        <errorDisplayField>BillingStreet</errorDisplayField>
        <errorMessage>Billing Street Is Required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Billing_Zipcode_Validation_Rule</fullName>
        <active>false</active>
        <description>Operations, New Operations
System Administrator, HG Sys Admin
SFDC Integrations</description>
        <errorConditionFormula>AND(
    ISBLANK(BillingPostalCode),
OR(NOT($Profile.Id = &quot;00e0b000001nOvW&quot;),NOT($Profile.Id = &quot;00e5a0000018d9a&quot;)),
OR(NOT($Profile.Id = &quot;00e0b000001iU5h&quot;),NOT($Profile.Id = &quot;00e5a000001OuCRAA0&quot;)),
OR(NOT($Profile.Id = &quot;00e5a000001Gfuk&quot;))
)</errorConditionFormula>
        <errorDisplayField>BillingPostalCode</errorDisplayField>
        <errorMessage>Billing Zip Code Is Required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Employee_Type_But_No_Employee_Selected</fullName>
        <active>true</active>
        <errorConditionFormula>IF( ISPICKVAL(Type, &apos;Employee&apos;)
   &amp;&amp; ISPICKVAL(Account_Status__c, &apos;Active&apos;) 
			&amp;&amp; ISBLANK(Employee__c), TRUE, FALSE)</errorConditionFormula>
        <errorDisplayField>Employee__c</errorDisplayField>
        <errorMessage>Employee Field needs to be filled in since this is an employee account</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Inactive_Request_Validation_Rule</fullName>
        <active>false</active>
        <errorConditionFormula>AND(ISPICKVAL(Account_Status__c ,&apos;Inactive Request&apos;), ISBLANK(TEXT( InactiveOnHoldReason__c)))</errorConditionFormula>
        <errorDisplayField>On_Hold_Reason__c</errorDisplayField>
        <errorMessage>Inactive - On Hold Reason Is Required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Inactive_Validation_Rule</fullName>
        <active>false</active>
        <errorConditionFormula>AND(ISPICKVAL(Account_Status__c ,&apos;Inactive&apos;), ISBLANK(TEXT( InactiveOnHoldReason__c)))</errorConditionFormula>
        <errorDisplayField>InactiveOnHoldReason__c</errorDisplayField>
        <errorMessage>Inactive - On Hold Reason Is Required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Main_Practitioner_Invalid_Change</fullName>
        <active>true</active>
        <description>This validation rule is in conjunction with a flow that will check if the Main Practioner you are changing to is within the same Practice Group. If so we allow the change if not, we stop the change.</description>
        <errorConditionFormula>Validation_Practice_Group_Change__c</errorConditionFormula>
        <errorDisplayField>Main_Practitioner__c</errorDisplayField>
        <errorMessage>The selected Practioner isn&apos;t apart of the same Practice Group. Please either revert the changes or choose a Practioner that is apart of the same Practice Group.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>No_Reactivation_of_Deleted_Account</fullName>
        <active>true</active>
        <description>This validation prevents an Account with an On Hold reason of &quot;Account Deletion Requested&quot; from having the status changed to active unless the User has a role of system administrator.</description>
        <errorConditionFormula>ISPICKVAL(Account_Status__c, &apos;Active&apos;)
	&amp;&amp;  ISPICKVAL(InactiveOnHoldReason__c, &apos;Account Deletion Requested&apos;)  
	&amp;&amp;  $UserRole.DeveloperName  &lt;&gt; &apos;System_Administration&apos;</errorConditionFormula>
        <errorMessage>This customer has requested that their Account be deleted, so the Account cannot be reactivated.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>On_Hold_Validation_Rule</fullName>
        <active>false</active>
        <errorConditionFormula>AND(ISPICKVAL(Account_Status__c ,&apos;On Hold&apos;), ISBLANK(TEXT( InactiveOnHoldReason__c)))</errorConditionFormula>
        <errorDisplayField>InactiveOnHoldReason__c</errorDisplayField>
        <errorMessage>Inactive - On Hold Reason Is Required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Only_RetTeam_AcctStatus_ActReq</fullName>
        <active>false</active>
        <description>Only Wellness Concierge profile can change Account Status = Inactive Request</description>
        <errorConditionFormula>AND(
$Profile.Name &lt;&gt; &apos;Wellness Concierge&apos;,
Case(
Account_Status__c ,
&apos;Inactive Request&apos;, 1,
0
)=1
)</errorConditionFormula>
        <errorDisplayField>Account_Status__c</errorDisplayField>
        <errorMessage>You are not required to submit this record for Account Status change approval. Do not select this status.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Practice_Group_Must_Be_Selected</fullName>
        <active>true</active>
        <description>If the Account is a Dr.Account, we must ensure it is tied to a practice group.</description>
        <errorConditionFormula>IF( ISNULL(Practice_Group__c) &amp;&amp; (RecordType.DeveloperName = 
			&apos;Affiliate_Doctor_Account_Record_Type&apos;) 
			, TRUE, FALSE)</errorConditionFormula>
        <errorDisplayField>Practice_Group__c</errorDisplayField>
        <errorMessage>Please select a Practice Group</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Prevent_Retention_Acct_Active_Status</fullName>
        <active>false</active>
        <description>You must submit this record for approval to update the Account Status = Inactive. Please update the Account Status = Activation Request. Save and then, hit the Submit for Approval Button. Thanks!</description>
        <errorConditionFormula>AND(
$Profile.Name = &apos;Wellness Concierge&apos;,
Case(
Account_Status__c ,
&apos;Inactive&apos;, 1,
0
)=1
)</errorConditionFormula>
        <errorDisplayField>Account_Status__c</errorDisplayField>
        <errorMessage>You must submit this record for approval to update the Account Status = Inactive. Please update the Account Status = Activation Request. Save and then, hit the Submit for Approval Button. Thanks!</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Restrict_Account_Owner_Name_Change</fullName>
        <active>false</active>
        <description>Prevent certain user, based on their profiles or role, to edit the account owner.

Operations, New Operations
System Administrator, HG Sys Admin</description>
        <errorConditionFormula>IF(  ISCHANGED( OwnerId  ), 
  IF(  
						OR(
										$UserRole.Name =&apos;Wellness Advisor Supervisor&apos;, 
										$UserRole.Name =&apos;Sales Director&apos;, 
										$UserRole.Name = &apos;Head of Sales&apos;,
										$UserRole.Name = &apos;Compliance Director&apos;,
										($Profile.Id = &quot;00e0b000001nOvW&quot;),
										($Profile.Id = &quot;00e5a0000018d9a&quot;),
										($Profile.Id = &quot;00e0b000001iU5h&quot;),
						    ($Profile.Id = &quot;00e5a000001OuCR&quot;)
						) ,false 
					, true) 				
			, false)</errorConditionFormula>
        <errorDisplayField>Ownership</errorDisplayField>
        <errorMessage>Contact your manager in order to change the account owner</errorMessage>
    </validationRules>
