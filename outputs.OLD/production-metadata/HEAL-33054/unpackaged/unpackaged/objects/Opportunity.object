SameAsShippingAddress__c = TRUE,
  ISBLANK(Account.ShippingStreet))</errorConditionFormula>
        <errorMessage>Please update the Shipping Address on the Account</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Supplements_Shipped_NO_EDIT</fullName>
