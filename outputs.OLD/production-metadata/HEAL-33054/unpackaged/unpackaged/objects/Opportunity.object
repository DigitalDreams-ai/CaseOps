    <validationRules>
        <fullName>Must_be_active_Promotion</fullName>
        <active>true</active>
        <description>This Validation Rule will evaluate if the promotion is active or not and prevent the user from creating a new record if promotion is inactive.</description>
        <errorConditionFormula>AND(
ISNEW(),
Promotion_Status__c = &quot;Inactive&quot;
)</errorConditionFormula>
        <errorMessage>The Promotion is inactive, please select an active promotion before proceeding.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>No_Opps_from_Inactive_Accounts</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
				$UserRole.Id != &apos;00E5a000001BBHR&apos;,
				ISPICKVAL( Account.Account_Status__c , &quot;Inactive&quot;),
    ISNEW()
)</errorConditionFormula>
        <errorMessage>Please change the Account Status from Inactive to create an opportunity.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Opp_Status_Validation_Rule</fullName>
        <active>true</active>
        <errorConditionFormula>AND(ISPICKVAL(StageName,&apos;Closed Won&apos;), ISBLANK(TEXT( Opportunity_Status__c)))</errorConditionFormula>
        <errorDisplayField>Opportunity_Status__c</errorDisplayField>
        <errorMessage>Opportunity Status is Required</errorMessage>
    </validationRules>
