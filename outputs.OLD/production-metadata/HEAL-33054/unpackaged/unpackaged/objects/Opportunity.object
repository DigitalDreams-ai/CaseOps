        <externalId>false</externalId>
        <label>2nd Tracking Number</label>
        <length>255</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Second_Tracking_URL__c</fullName>
        <externalId>false</externalId>
        <formula>IF(
 TEXT(Second_Shipping_Company__c) = &quot;Fedex&quot;,
 &quot;https://www.fedex.com/apps/fedextrack/index.html?tracknumbers=&quot; + Second_Tracking_Num__c + &quot;&amp;cntry_code=us&quot;,

 IF(
  TEXT(Second_Shipping_Company__c) = &quot;UPS&quot;,
  &quot;https://www.ups.com/track?loc=en_US&amp;tracknum=&quot; + Second_Tracking_Num__c + &quot;&amp;requester=WT/trackdetails&quot;,

  IF(
   TEXT(Second_Shipping_Company__c) = &quot;USPS&quot;,
   &quot;https://tools.usps.com/go/TrackConfirmAction?tRef=fullpage&amp;tLc=2&amp;text28777=&amp;tLabels=&quot; + Second_Tracking_Num__c,

   IF(
    TEXT(Second_Shipping_Company__c) = &quot;DHL eCommerce&quot;,
    &quot;https://www.dhl.com/us-en/home/tracking.html?tracking-id=&quot; + Second_Tracking_Num__c,

    NULL
   )
  )
 )
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>2nd Tracking URL</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
