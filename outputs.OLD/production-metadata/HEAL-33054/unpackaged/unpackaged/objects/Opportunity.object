+ CASESAFEID(Id) + &quot;__&quot; + CASESAFEID(AccountId) + IF(ISNULL(Genetic_Test_ReShip_Attempt__c), &quot;&quot;, &quot;__&quot; + TEXT(Genetic_Test_ReShip_Attempt__c))</formula>
