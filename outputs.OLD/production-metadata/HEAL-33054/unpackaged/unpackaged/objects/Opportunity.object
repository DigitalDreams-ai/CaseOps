    <validationRules>
        <fullName>Shipping_Address_Required</fullName>
        <active>false</active>
        <description>VR enforcing users to ensure there is a shipping address associated with a Medication or Genetic Testing record type.</description>
        <errorConditionFormula>AND(
TEXT(StageName) = &quot;Waiting For Approval&quot;,
ISCHANGED(StageName),
OR(
ISBLANK(Shipping_Street_Address__c),
ISBLANK(Shipping_City__c),
ISBLANK(Shipping_State__c),
ISBLANK(Shipping_Country__c),
ISBLANK(Shipping_Zip_Code__c),
ISNULL(Shipping_Street_Address__c),
ISNULL(Shipping_City__c),
ISNULL(Shipping_State__c),
ISNULL(Shipping_Country__c),
ISNULL(Shipping_Zip_Code__c),
RecordType.Name = &apos;Medication&apos;,
RecordType.Name = &apos;Genetic Testing&apos;
)
)</errorConditionFormula>
        <errorMessage>Please Select a Shipping Address</errorMessage>
    </validationRules>
