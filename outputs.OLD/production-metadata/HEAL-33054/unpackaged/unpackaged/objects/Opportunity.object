    <fields>
        <fullName>Issues_Founded__c</fullName>
        <externalId>false</externalId>
        <formula>IF(
     INCLUDES(Account.Issues__c , &quot;Difficult Person&quot;),
     IMAGE(&quot;img/msg_icons/error16.png&quot;, &quot;Difficult Person&quot;),
     null
) &amp; &quot; &quot; &amp;
IF(
     INCLUDES(Account.Issues__c , &quot;Refund&quot;),
     IMAGE(&quot;img/msg_icons/error16.png&quot;, &quot;Refund&quot;),
     null
) &amp; &quot; &quot; &amp;
IF(
     INCLUDES(Account.Issues__c , &quot;Chargeback&quot;),
     IMAGE(&quot;img/msg_icons/error16.png&quot;, &quot;Chargeback&quot;),
     null
)
&amp; &quot; &quot; &amp;
IF(
     INCLUDES(Account.Issues__c , &quot;See Notes&quot;),
     IMAGE(&quot;img/msg_icons/error16.png&quot;, &quot;See Notes&quot;),
     null
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Issues Founded</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Issues_Type__c</fullName>
        <externalId>false</externalId>
        <formula>IF(INCLUDES(Account.Issues__c , &apos;Difficult Person&apos;),&quot;Difficult Person; &quot;, null) +
IF( INCLUDES( Account.Issues__c , &apos;Refund&apos;),&quot;Refund; &quot;, null) +
IF( INCLUDES(Account.Issues__c, &apos;Chargeback&apos;), &apos;Chargeback; &apos;, null) +
IF( INCLUDES(Account.Issues__c, &apos;See Notes&apos;), &apos;See Notes&apos;, null)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Issues Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
