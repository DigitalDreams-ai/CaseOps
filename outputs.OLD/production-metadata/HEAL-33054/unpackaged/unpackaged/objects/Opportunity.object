    <sharingModel>Private</sharingModel>
    <validationRules>
        <fullName>Account_Status</fullName>
        <active>true</active>
        <description>If the Account status is cancelled or suspended we do not want to allow opportunities to be created.</description>
        <errorConditionFormula>OR(
ISPICKVAL(Account.Account_Status__c, &apos;Cancelled&apos;),
ISPICKVAL(Account.Account_Status__c, &apos;Suspended&apos;)
				)</errorConditionFormula>
        <errorMessage>You are not allowed to make create an Opportunity for this Account because it is Suspended.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Account_is_Set_to_Net_Term</fullName>
        <active>true</active>
        <description>if the Account is set to net term, then require net term to be set on the Opportunity.</description>
        <errorConditionFormula>AND(
Account.Net_Terms__c, 
ISBLANK(TEXT( Net_Payment_Terms__c )),
$UserRole.Id != &apos;00E5a000001BBHR&apos;
)</errorConditionFormula>
        <errorDisplayField>Net_Payment_Terms__c</errorDisplayField>
        <errorMessage>The account is Net Termed; Please Select a Net Payment Terms.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Address_Checker</fullName>
        <active>false</active>
        <description>This VR will check to ensure there is an address associated with the medication Opportunity type.</description>
        <errorConditionFormula>AND(
NOT(ISNEW()),
ISPICKVAL( StageName , &apos;Open&apos;),
SameAsShippingAddress__c = FALSE,
SameAsBillingAddress__c = FALSE,
RecordType.Name = &apos;Medication&apos;
)</errorConditionFormula>
        <errorMessage>Update Address on Opportunity</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Approved_NO_EDIT</fullName>
        <active>false</active>
        <errorConditionFormula>AND(
ISPICKVAL(PRIORVALUE(StageName),&quot;Approved&quot;),
NOT($Profile.Id = &quot;00e0b000001nOvW&quot;),
NOT($Profile.Id = &quot;00e0b000001iU5h&quot;),
NOT($Profile.Id = &quot;00e5a000001OuCR&quot;),
NOT($Profile.Id = &quot;00e0b000001nOvl&quot;)
)</errorConditionFormula>
        <errorMessage>You Can Not Edit This Opportunity Because Has Been Approved</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Billing_Shipping_Address_Checkbox</fullName>
        <active>false</active>
        <description>This VR will check to see if Same As Billing Address or Same As Shipping Address is blank on the Opportunity</description>
        <errorConditionFormula>AND(
ISPICKVAL( StageName , &apos;Waiting For Approval&apos;),
  SameAsShippingAddress__c = FALSE,
  SameAsBillingAddress__c = FALSE,
  RecordType.Name = &apos;Medication&apos;
  )</errorConditionFormula>
        <errorMessage>Same As Shipping Address or Same As Billing Address is blank on this Opportunity. Please select one.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Close_Won_NO_EDIT</fullName>
        <active>true</active>
        <description>Operations Admin
System Administrator
New Finance
Shipping Coordinator
Office Staff</description>
        <errorConditionFormula>AND(
    ISPICKVAL(PRIORVALUE(StageName),&quot;Closed Won&quot;),
    NOT($Profile.Id = &quot;00e5a0000018d9a&quot;),
    NOT($UserRole.Id = &quot;00E5a000001BBHR&quot;),
    NOT($Profile.Id = &quot;00e5a0000018d9G&quot;),
    NOT($UserRole.Id = &quot;00E5a000001QTSr&quot;),
    NOT($UserRole.Id = &quot;00E5a000001QTSm&quot;),
    NOT($Permission.Opportunity_Edit_Closed_Won)
)</errorConditionFormula>
        <errorMessage>You Can Not Edit This Opportunity Because Has Been Closed Won</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Closed_Lost_Reason</fullName>
        <active>false</active>
        <errorConditionFormula>AND(ISPICKVAL(StageName,&apos;Closed Lost&apos;), ISBLANK(TEXT(  Closed_Lost_Reason__c )))</errorConditionFormula>
        <errorDisplayField>Closed_Lost_Reason__c</errorDisplayField>
        <errorMessage>Close Lost Reason is Required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Completed_No_EDIT</fullName>
        <active>true</active>
        <description>This validation rule will prevent users from editing Telehealth records after it has been completed

Operations Admin
System Administrator
HG SysAdmin
Finance
New_Finance
Shipping Coordinator
Patient Support Rep
Nico Cortes</description>
        <errorConditionFormula>AND(
ISPICKVAL(PRIORVALUE(StageName),&quot;Completed&quot;),
NOT($Profile.Id = &quot;00e5a0000018d9a&quot;),
NOT($UserRole.Id = &quot;00E5a000001BBHR&quot;),
NOT($Profile.Id = &quot;00e5a000001OuCRAA0&quot;),
NOT($Profile.Id = &quot;00e0b000001nOvl&quot;),
NOT($Profile.Id = &quot;00e5a0000018d9G&quot;),
NOT($UserRole.Id = &quot;00E5a000001QTSr&quot;),
NOT($UserRole.Id = &quot;00E5a000001QTT6&quot;),
NOT($User.Id = &quot;0055a000007g7PV&quot;)
)</errorConditionFormula>
        <errorMessage>You Can Not Edit This Opportunity Because Has Been Completed.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Consult_Notes_Req_On_Won_Consultation</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
				NOT($UserRole.Name = &quot;System Administration&quot;),
				ISBLANK(Consult_Notes__c),
				RecordType.Name = &quot;Consultation&quot;, 
				ISPICKVAL(StageName, &quot;Completed&quot;)
)</errorConditionFormula>
        <errorDisplayField>Consult_Notes__c</errorDisplayField>
        <errorMessage>You must enter Consult Notes on Completed Consultation Opportunities</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Credit_Card_Validation_Rule</fullName>
        <active>true</active>
        <errorConditionFormula>ISPICKVAL(Transaction_Type__c, &apos;Credit Card&apos;) &amp;&amp;
Credit_Card__c == NULL &amp;&amp;
RecordType.Name &lt;&gt; &apos;Telehealth&apos; &amp;&amp;
NOT($User.Skip_Automation_Rules__c)</errorConditionFormula>
        <errorDisplayField>Credit_Card__c</errorDisplayField>
        <errorMessage>Please Choose a Credit Card</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>First_Shipping_Date_Validation_Rule</fullName>
        <active>true</active>
        <errorConditionFormula>AND(ISPICKVAL(StageName,&apos;Closed Won&apos;), ISBLANK(TEXT(  First_Shipping_Date__c )))</errorConditionFormula>
        <errorDisplayField>First_Shipping_Date__c</errorDisplayField>
        <errorMessage>1st Shipping Date is Required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>GT_Shipping_Information</fullName>
        <active>false</active>
        <description>This VR will require shipping information to be filled out completely for Genetic Test record types that require shipping</description>
        <errorConditionFormula>AND(
    NOT(ISNEW()), 
    RecordType.Name  == &apos;Genetic Testing&apos;,
    Requires_Shipping__c = TRUE,
     OR(
        ISBLANK(Shipping_Street_Address__c),
        ISBLANK(Shipping_City__c),
        ISBLANK(Shipping_State__c),
        ISBLANK(Shipping_Country__c),
        ISBLANK(Shipping_Zip_Code__c)
))</errorConditionFormula>
        <errorMessage>Please ensure all shipping information is filled out for this Genetic Testing Opportunity.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Kit_ID_Required_if_Not_Shipping</fullName>
        <active>false</active>
        <errorConditionFormula>IF(
    /* Check if Kit_Id__c is being edited and Requires_Shipping__c is true */
    AND(
								NOT($UserRole.Id = &quot;00E5a000001BBHR&quot;),
        ISCHANGED(Kit_Id__c), 
								NOT(ISCHANGED(Genetic_Test_ReShip_Attempt__c)),
        Requires_Shipping__c
    ), 
    TRUE, /* If both conditions are true, block the change */
    
    /* Else, evaluate further conditions */
    AND(
								ISCHANGED(Kit_Id__c),
								NOT(ISCHANGED(Genetic_Test_ReShip_Attempt__c)),
        /* Ensure the user&apos;s role is not the one exempted from this rule */
        NOT($UserRole.Id = &quot;00E5a000001BBHR&quot;),
        
        OR(
            /* If &quot;Need More Information&quot;, ensure Opportunity_Status__c is not &quot;Kit Id Missing&quot; */
            AND(
                ISPICKVAL(StageName, &quot;Need More Information&quot;),
                NOT(ISPICKVAL(Opportunity_Status__c, &quot;Kit Id Missing&quot;))
            ),
            
            /* Block if the stage is neither &quot;New Purchase&quot; nor &quot;Need More Information&quot; */
            NOT(
                OR(
                    ISPICKVAL(StageName, &quot;New Purchase&quot;),
                    ISPICKVAL(StageName, &quot;Need More Information&quot;),
                    ISPICKVAL(StageName, &quot;Pending Results&quot;)
                )
            )
        )
    ) /* If further conditions are met, block the change. Otherwise, allow it. */
)</errorConditionFormula>
        <errorDisplayField>Kit_Id__c</errorDisplayField>
        <errorMessage>Kit ID can only be edited in the &apos;New Purchase&apos; or &apos;Needs More Information&apos; stages with no shipping required. For &apos;Need More Information&apos;, the Opportunity Status must be &apos;Kit Id Missing&apos;.</errorMessage>
    </validationRules>
