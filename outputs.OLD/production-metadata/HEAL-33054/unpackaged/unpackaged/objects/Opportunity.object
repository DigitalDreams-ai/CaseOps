    </fields>
    <fields>
        <fullName>Probability</fullName>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
    </fields>
    <fields>
        <fullName>Product_List_Price__c</fullName>
        <label>Product List Price</label>
        <summarizedField>OpportunityLineItem.ListPrice</summarizedField>
        <summaryForeignKey>OpportunityLineItem.OpportunityId</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>Product_Total_Price__c</fullName>
        <label>Product Total Price</label>
        <summarizedField>OpportunityLineItem.TotalPrice</summarizedField>
        <summaryForeignKey>OpportunityLineItem.OpportunityId</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>Promotion_Amount__c</fullName>
        <formula>IF(Aesthetics_Promotion__c != NULL,Aesthetics_Promotion__r.Promotion_Amount__c ,
IF(Genetic_Testing_Promotion__c != NULL,Genetic_Testing_Promotion__r.Promotion_Amount__c ,
IF(Hormone_Evaluation_Promotion__c != NULL,  Hormone_Evaluation_Promotion__r.Promotion_Amount__c,
IF(Lab_Promotion__c != NULL,  Lab_Promotion__r.Promotion_Amount__c,
IF(Medication_Promotion__c != NULL, Medication_Promotion__r.Promotion_Amount__c,
IF(Medical_Consultation_Promotion__c != NULL,  Medical_Consultation_Promotion__r.Promotion_Amount__c , 
IF(Sexual_Wellness_Promotion__c != NULL, Sexual_Wellness_Promotion__r.Promotion_Amount__c, 0.00)

			
)

)

))))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Promotion Amount</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>Promotion_Applied__c</fullName>
        <formula>IF(Genetic_Testing_Promotion__c != NULL ||Aesthetics_Promotion__c != NULL ||  Sexual_Wellness_Promotion__c != NULL ||  Lab_Promotion__c != Null || Hormone_Evaluation_Promotion__c != NULL ||  Medical_Consultation_Promotion__c != NULL || Medication_Promotion__c != NULL, TRUE, FALSE)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Promotion Applied</label>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Promotion_Status__c</fullName>
        <externalId>false</externalId>
        <formula>IF(Aesthetics_Promotion__c != NULL,TEXT(Aesthetics_Promotion__r.Promotion_Status__c) ,
IF(Hormone_Evaluation_Promotion__c != NULL,TEXT(Hormone_Evaluation_Promotion__r.Promotion_Status__c),
IF(Lab_Promotion__c != NULL, TEXT(Lab_Promotion__r.Promotion_Status__c),
IF(Medication_Promotion__c != NULL, TEXT(Medication_Promotion__r.Promotion_Status__c),
IF(Genetic_Testing_Promotion__c != NULL,TEXT(Genetic_Testing_Promotion__r.Promotion_Status__c),
IF(Medical_Consultation_Promotion__c != NULL, TEXT(Medical_Consultation_Promotion__r.Promotion_Status__c ),
IF(Sexual_Wellness_Promotion__c != NULL, TEXT(Sexual_Wellness_Promotion__r.Promotion_Status__c), NULL)

)

)

))))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Promotion Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
