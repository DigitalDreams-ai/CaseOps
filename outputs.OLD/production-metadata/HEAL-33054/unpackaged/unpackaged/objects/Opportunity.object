ISPICKVAL(PRIORVALUE(StageName),&quot;Supplements Shipped&quot;),
NOT($Profile.Id = &quot;00e0b000001nOvW&quot;),
NOT($Profile.Id = &quot;00e5a0000018d9a&quot;),
NOT($Profile.Id = &quot;00e0b000001iU5h&quot;),
NOT($Profile.Id = &quot;00e5a000001OuCRAA0&quot;),
NOT($Profile.Id = &quot;00e0b000001nOvl&quot;),
NOT($Profile.Id = &quot;00e5a0000018d9G&quot;)
)</errorConditionFormula>
        <errorMessage>You Can Not Edit This Opportunity Supplements Have Been Shipped.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>User_Changed_Status_WaitingForApproval</fullName>
        <active>true</active>
        <description>Do not allow the user to change the status to &quot;Waiting For Approval&quot;</description>
        <errorConditionFormula>AND(
OR(ISNEW(),
ISCHANGED(StageName)
),
TEXT(StageName) = &apos;Waiting For Approval&apos;,
NOT($Profile.Id = &apos;00e5a000001Gfuk&apos;),
NOT($Profile.Id = &apos;00e0b000001iU5h&apos;)
)</errorConditionFormula>
        <errorMessage>Please use the &quot;Submit For Approval&quot; button in the action bar on the top right of this page. This will notify the operations team.</errorMessage>
    </validationRules>
