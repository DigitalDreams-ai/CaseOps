<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Opportunity_Refunded</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  Opportunity_Refunded__c == TRUE, 
  ISBLANK(Opportunity_Refunded_Date_del__c)
)</errorConditionFormula>
    <errorDisplayField>Opportunity_Refunded_Date_del__c</errorDisplayField>
    <errorMessage>Please Enter The Refunded Date</errorMessage>
</ValidationRule>
