<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>No_Opps_from_Inactive_Accounts</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
				$UserRole.Id != &apos;00E5a000001BBHR&apos;,
				ISPICKVAL( Account.Account_Status__c , &quot;Inactive&quot;),
    ISNEW()
)</errorConditionFormula>
    <errorMessage>Please change the Account Status from Inactive to create an opportunity.</errorMessage>
</ValidationRule>
