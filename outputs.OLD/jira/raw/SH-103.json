      "created": "2025-10-31T11:30:51.974-0700",
      "duedate": null,
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Context",
                "marks": [
                  {
                    "type": "strong"
                  },
                  {
                    "type": "underline"
                  }
                ]
              },
              {
                "type": "text",
                "text": ": In WC there is a concept of “Labor Market Attachment” where a client is found to have a  partial disability and therefore is under an obligation to look for work. We have no real way of tracking this outside of a task tree. "
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "User Story",
                "marks": [
                  {
                    "type": "strong"
                  },
                  {
                    "type": "underline"
                  }
                ]
              },
              {
                "type": "text",
                "text": ": As paralegal I want to track cases where work search has been directed by the Judge and when I submit evidence of the client’s wokr search. "
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Requirement",
                "marks": [
                  {
                    "type": "strong"
                  },
                  {
                    "type": "underline"
                  }
                ]
              },
              {
                "type": "text",
                "text": ": "
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "New Fields",
                "marks": [
                  {
                    "type": "strong"
                  }
                ]
              },
              {
                "type": "text",
                "text": ":"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Work Search Directed - Date Field"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Work Search Last Submitted - Date Field"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Automation",
                "marks": [
                  {
                    "type": "strong"
                  }
                ]
              },
              {
                "type": "text",
                "text": ": "
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "In the WC Hearing Note flow there is a dropdown on the Task section that includes an option for Work Search. "
              }
            ]
          },
          {
            "type": "mediaSingle",
            "attrs": {
              "width": 671,
              "widthType": "pixel",
              "layout": "align-start"
            },
            "content": [
              {
                "type": "media",
                "attrs": {
                  "type": "file",
                  "id": "acb6b4de-2b71-43db-8b56-90a6e86d5976",
                  "alt": "image-20251031-182957.png",
                  "collection": "",
                  "height": 515,
                  "width": 1034
                }
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "This currently triggers a task tree. We also want to add an additional update to the matter to fill the Work Search Directed date field with the Scheduled Date field from the Hearing record. "
              }
            ]
          }
        ]
      },
