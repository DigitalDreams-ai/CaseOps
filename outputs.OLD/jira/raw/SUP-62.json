    "fields": {
      "summary": "Consolidate Login Authentication",
      "attachment": [],
      "created": "2026-05-28T13:43:38.304-0700",
      "duedate": null,
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The analytics team had a quick question regarding our current Salesforce access. At the moment, we are required to go through two-factor authentication each time we log in. The team wanted to check whether the authentication code could be sent directly to "
              },
              {
                "type": "text",
                "text": "analytics@hennessey.com",
                "marks": [
                  {
                    "type": "link",
                    "attrs": {
                      "href": "mailto:analytics@hennessey.com"
                    }
                  }
                ]
              },
              {
                "type": "text",
                "text": " instead of needing to reach out to your team for the code each time."
              }
            ],
            "attrs": {
              "localId": "7d09edcae2c7"
            }
          }
        ]
      },
