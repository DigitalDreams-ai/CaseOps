                <componentInstanceProperties>
                    <name>richTextValue</name>
                    <value>&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;Hi {{{Recipient.FirstName}}},&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;It has been a pleasure to be a part of your 10X Health Care Team!&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;I&amp;#39;d like to introduce you to my colleague, Devin.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;Devin is your Wellness Concierge. His responsibility is to handhold you on your journey to optimal health! Devin will be your point of contact moving forward to ensure we set you up for success along the way!&amp;nbsp;Here&amp;#39;s a little more about your Concierge:&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;With over a decade of experience in healthcare and fitness training. Devin brings expertise from diverse roles, including sports coaching, paramedic work, and fitness training.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;Driven by a personal passion for wellness, Devin is committed to helping individuals achieve their health goals and improve their quality of life.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;Devin, {{{Recipient.FirstName}}} shared some of the top wellness goals below:&lt;/span&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;&lt;b&gt;INSERT GOALS&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;&lt;b&gt;INSERT GOALS&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;&lt;b&gt;INSERT GOALS&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;{{{Recipient.FirstName}}}, Devin is fully prepared to provide you with the support you need to 10X your health through monthly check ins, answering questions, and keeping you on track with your protocol!&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;Your first meeting with Devin will be on &lt;strong&gt;[Date &amp;amp; Time]&lt;/strong&gt;. Keep an eye out for a calendar invite and reminders coming your way! Devin will connect with you to go over your next steps: completing an inventory check, walking you through your protocol, and ensuring you feel fully confident with your medications when they arrive.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;&lt;b&gt;Heads up&lt;/b&gt;: If anything&amp;nbsp;is lost, missing, or damaged, please let us know within 24 hours and send a quick photo.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;In the meantime, if you have any questions or need to reschedule your call with Devin, please don&amp;#39;t hesitate to reply to this email or click on the scheduling link.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;a href=&quot;https://&quot;&gt;https://calendly.com/ddelvalle10xhealth/precision-wellness-protocol-welcome-inventory-check&lt;/a&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;You can contact Devin directly via email at&amp;nbsp;ddelvalle@10xhealthsystem.com&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;In Health,&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Tahoma,Arial,Helvetica,sans-serif;&quot;&gt;Your 10X Care Team&lt;/span&gt;&lt;/p&gt;</value>
