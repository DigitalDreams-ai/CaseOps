                <componentInstanceProperties>
                    <name>richTextValue</name>
                    <value>&lt;p&gt;&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;Hi &lt;/span&gt;&lt;/span&gt;{{{Account.FirstName}}}&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;,&lt;/span&gt;&lt;/span&gt;&lt;br /&gt;
&amp;nbsp;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;You&amp;#39;re ready for your 10X Blood work.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;font face=&quot;Verdana, Arial, Helvetica, sans-serif&quot;&gt;You&amp;#39;re about to take the first step toward unlocking your personalized wellness blueprint with your 10X Blood Work. Your blood test will be processed through our mobile lab partner, ACCESS, powered by Evexia.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;

&lt;p&gt;&lt;font face=&quot;Verdana, Arial, Helvetica, sans-serif&quot;&gt;Within 2-3 business days, you&amp;#39;ll be contacted to schedule your blood draw. You will also receive a collection kit in 7-10 business days. This kit will have your lab requisition, ice packs, and blood draw supplies.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;&lt;strong&gt;Before Your Blood Draw (Important!)&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;br /&gt;
&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;To ensure the most accurate results:&amp;nbsp;&lt;/span&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;Fast for 8-10 hours prior to your draw&lt;/span&gt;&lt;/li&gt;
	&lt;li&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;Do NOT take supplements or hormones the morning of&lt;/span&gt;&lt;/li&gt;
	&lt;li&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;Do take prescribed medications for chronic conditions (e.g., hypertension)&lt;/span&gt;&lt;/li&gt;
	&lt;li&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;Men: Go the day before your next testosterone dose&amp;nbsp;&lt;/span&gt;&lt;/li&gt;
	&lt;li&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;Women: If menstruating, aim for day 19,20, or 21 of your cycle&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;&lt;strong&gt;Need help?&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;Reach out to&lt;/span&gt;&amp;nbsp;{{{Account.Owner_First_Name__c}}} &lt;span style=&quot;font-family:Verdana,Arial,Helvetica,sans-serif;&quot;&gt;with any questions, we&amp;#39;re here to support your path to optimal wellness.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;</value>
