    <collectionProcessors>
        <name>Collection_Informed_Consents</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Collection Informed Consents</label>
        <locationX>358</locationX>
        <locationY>350</locationY>
        <assignNextValueToReference>currentItem_Collection_Informed_Consents</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_Patient_Agreements</collectionReference>
        <conditionLogic>1 AND NOT(2) AND NOT(3)</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Collection_Informed_Consents.Name</leftValueReference>
            <operator>Contains</operator>
            <rightValue>
                <stringValue>Informed Consent</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Collection_Informed_Consents.Expiration_Date__c</leftValueReference>
            <operator>LessThan</operator>
            <rightValue>
                <elementReference>$Flow.CurrentDate</elementReference>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Collection_Informed_Consents.Name</leftValueReference>
            <operator>Contains</operator>
            <rightValue>
                <stringValue>PGT</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Assign_Informed_Consents</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
        <name>Filter_Existing_Patient_Agreements</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Filter Existing Patient Agreements</label>
        <locationX>864</locationX>
        <locationY>2090</locationY>
        <assignNextValueToReference>currentItem_Filter_Existing_Patient_Agreements</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_Patient_Agreements</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Filter_Existing_Patient_Agreements.Patient_Agreement_Configuration__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <elementReference>Loop_Through_Patient_Agreement_Configurations.Id</elementReference>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Count_Filter_Records</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
        <name>PA_from_PAC</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>PA from PAC</label>
        <locationX>666</locationX>
        <locationY>4478</locationY>
        <assignNextValueToReference>currentItem_PA_from_PAC</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_Patient_Agreements</collectionReference>
        <conditionLogic>1 AND ((2 AND 3 AND 5) AND 4)</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_PA_from_PAC.Patient_Agreement_Configuration__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <elementReference>Loop_Through_Patient_Agreement_Configurations.Id</elementReference>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_PA_from_PAC.Status__c</leftValueReference>
            <operator>NotEqualTo</operator>
            <rightValue>
                <stringValue>Approved</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_PA_from_PAC.Status__c</leftValueReference>
            <operator>NotEqualTo</operator>
            <rightValue>
                <stringValue>Rejected</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_PA_from_PAC.Expiration_Date__c</leftValueReference>
            <operator>LessThan</operator>
            <rightValue>
                <elementReference>$Flow.CurrentDate</elementReference>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_PA_from_PAC.Status__c</leftValueReference>
            <operator>NotEqualTo</operator>
            <rightValue>
                <stringValue>Inferred Consent</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>PA_Status</targetReference>
        </connector>
    </collectionProcessors>
    <constants>
        <name>const_FlowName</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Autolaunch_Send_Patient_Agreements_to_Patient</stringValue>
        </value>
    </constants>
    <decisions>
        <description>Depending on how the recurrence is setup is if we set different field values</description>
        <name>Configuration_Recurrence</name>
        <label>Configuration Recurrence</label>
        <locationX>864</locationX>
        <locationY>3338</locationY>
        <defaultConnector>
            <targetReference>Log_Configuration_Recurrence_Continue</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Continue</defaultConnectorLabel>
        <rules>
            <name>Recurrence_Schedule_X_Months</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Through_Patient_Agreement_Configurations.Recurrence_Schedule__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>X Months</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Recurrence_Schedule_X_Months</targetReference>
            </connector>
            <label>Recurrence Schedule - X Months</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if bool_hasInformedConsent is true</description>
        <name>Did_we_find_Informed_consent</name>
        <label>Did we find Informed consent</label>
        <locationX>50</locationX>
        <locationY>1490</locationY>
        <defaultConnector>
            <targetReference>Adding_Of_Element_To_Collection</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Need to add IC</defaultConnectorLabel>
        <rules>
            <name>Already_has_IC</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>bool_hasInformedConsent</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Through_Patient_Agreement_Configurations</targetReference>
            </connector>
            <label>Already has IC</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if there are any PA to update</description>
        <name>Do_we_need_to_update_records</name>
        <label>Do we need to update records</label>
        <locationX>358</locationX>
        <locationY>5678</locationY>
        <defaultConnector>
            <targetReference>Log_Entry_No_Records_to_update</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No records to update</defaultConnectorLabel>
        <rules>
            <name>Need_to_update</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>col_PatientAgreementsToUpdate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Patient_Agreement_Records</targetReference>
            </connector>
            <label>Need to update</label>
        </rules>
    </decisions>
    <decisions>
        <name>Does_Agreement_Match_Configuration1</name>
        <label>Does Agreement Match Configuration?</label>
        <locationX>864</locationX>
        <locationY>4262</locationY>
        <defaultConnector>
            <targetReference>Log_No_Matching</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>num_CountFilteredPatientAgreements</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Yes_Match</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if the account record (patient) has Biocanic Id assigned. If there is not Biocanic Id, the Creation Source needs to be MyWellness Portal</description>
        <name>Does_Patient_have_Biocanic_Id</name>
        <label>Does Patient have Biocanic Id</label>
        <locationX>864</locationX>
        <locationY>2930</locationY>
        <defaultConnector>
            <targetReference>Log_No_Biocanic_Id</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Does NOT have Biocanic Id</defaultConnectorLabel>
        <rules>
            <name>Has_Biocanic_Id</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rec_Account.Biocanic_External_Id__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>form_SetupDoNotSyncBiocanic</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rec_Account.Do_Not_Sync_to_Biocanic__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Configuration_Recurrence</targetReference>
            </connector>
            <label>Has Biocanic Id</label>
        </rules>
    </decisions>
    <decisions>
        <name>Has_Collection_Found_Element</name>
        <label>Has Collection Found Element</label>
        <locationX>358</locationX>
        <locationY>566</locationY>
        <defaultConnector>
            <targetReference>Log_Collection_Found_Element</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Found</defaultConnectorLabel>
        <rules>
            <name>Not_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>num_CountInformedConsentsPatientAgreements</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Collection_Not_Found_Element</targetReference>
            </connector>
            <label>Not Found</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if current PAC is Informed Consent</description>
        <name>Is_it_Informed_consent</name>
        <label>Is it Informed consent</label>
        <locationX>270</locationX>
        <locationY>998</locationY>
        <defaultConnector>
            <targetReference>Loop_through_passed_in_PAC</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Informed Consent</defaultConnectorLabel>
        <rules>
            <name>Informed_Consent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_through_passed_in_PAC.Id</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_Patient_Agreement_Configuration.Id</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Mark_Has_Informed_Consent</targetReference>
            </connector>
            <label>Informed Consent</label>
        </rules>
    </decisions>
    <decisions>
        <description>If the Opportunity Record is passed in then we can assign that on the Patient Agreement Record</description>
        <name>Is_Opportunity_Record_Passed_In</name>
        <label>Is Opportunity Record Passed In</label>
        <locationX>864</locationX>
        <locationY>2414</locationY>
        <defaultConnector>
            <targetReference>Log_No_Opportunity_Record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Opportunity Id</defaultConnectorLabel>
        <rules>
            <name>Opportunity_Record_Passed_In</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rec_Opportunity</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Opportunity_Record_Passed_In</targetReference>
            </connector>
            <label>Opportunity Record Passed In</label>
        </rules>
    </decisions>
    <decisions>
        <description>If Child Patient Agreement is set this means that we need to set this on the &quot;child&quot; record to be able to track these records together.</description>
        <name>Is_Original_Patient_Agreement_Set</name>
        <label>Is Original Patient Agreement Set</label>
        <locationX>864</locationX>
        <locationY>3746</locationY>
        <defaultConnector>
            <targetReference>Log_Original_Patient_Account_is_NOT_Set</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Original Patient Account is NOT Set</defaultConnectorLabel>
        <rules>
            <name>Original_Patient_Account_is_Set</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rec_Original_PatientAgreement</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Log_Original_Patient_Account_is_Set</targetReference>
            </connector>
            <label>Original Patient Account is Set</label>
        </rules>
    </decisions>
    <decisions>
        <name>PA_Status</name>
        <label>PA Status?</label>
        <locationX>666</locationX>
        <locationY>4586</locationY>
        <defaultConnector>
            <targetReference>Log_Approved_Rejected</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Approved/Rejected and not Expired</defaultConnectorLabel>
        <rules>
            <name>Put_to_Implied_Consent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>PA_from_PAC</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_through_Implied_Consent</targetReference>
            </connector>
            <label>Put to Implied Consent</label>
        </rules>
    </decisions>
    <description>In this flow we will take the passed in Patient Configuration Agreements and create patient agreements. Updated Logs to contain the formula which will check if there is opportunity record, if not, then account record.</description>
    <environments>Default</environments>
    <formulas>
        <name>form_ExpirationDate</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS({!$Flow.CurrentDate},{!Loop_Through_Patient_Agreement_Configurations.Number_of_Months_for_Recurrence__c})</expression>
    </formulas>
    <formulas>
        <name>form_OpportunityOrAccount</name>
        <dataType>String</dataType>
        <expression>IF(
    NOT(ISBLANK({!rec_Opportunity.Id})), 
    {!rec_Opportunity.Id}, 
    IF(
        NOT(ISBLANK({!rec_Account.Id})), 
        {!rec_Account.Id}, 
        &apos;&apos;
    )
)</expression>
    </formulas>
    <formulas>
        <name>form_SetupDoNotSyncBiocanic</name>
        <dataType>Boolean</dataType>
        <expression>{!$Setup.AutomationControlSettings__c.Do_Not_Sync_to_Biocanic__c}</expression>
    </formulas>
    <formulas>
        <name>TodayMinusXMonths</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS(TODAY(), -{!Loop_Through_Patient_Agreement_Configurations.Number_of_Months_for_Recurrence__c})</expression>
    </formulas>
    <interviewLabel>Autolaunch - Send Patient Agreements to Patient {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Autolaunch - Create Patient Agreements</label>
    <loops>
        <name>Loop_through_Implied_Consent</name>
        <label>Loop through Implied Consent</label>
        <locationX>534</locationX>
        <locationY>4694</locationY>
        <collectionReference>PA_from_PAC</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_implied_consent</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Log_Put_To_Implied_Consent</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <description>Loop through passed in PAC to see if IC is already in the list</description>
        <name>Loop_through_passed_in_PAC</name>
        <label>Loop through passed in PAC</label>
        <locationX>50</locationX>
        <locationY>890</locationY>
        <collectionReference>col_PatientAgreementConfigurtion</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Is_it_Informed_consent</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Did_we_find_Informed_consent</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_Through_Patient_Agreement_Configurations</name>
        <label>Loop Through Patient Agreement Configurations</label>
        <locationX>358</locationX>
        <locationY>1982</locationY>
        <collectionReference>col_PatientAgreementConfigurtion</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Filter_Existing_Patient_Agreements</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Log_Entry_Patient_Agreement_Records_Loop_Completed_and_records_added_into_List</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>From the above loop we will create new patient agreement records</description>
        <name>Create_Patient_Agreement_Records</name>
        <label>Create Patient Agreement Records</label>
        <locationX>358</locationX>
        <locationY>6218</locationY>
        <connector>
            <targetReference>Add_Log_Entry_for_an_SObject_Record_Collection_Action_1</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_Error_Creating_Patient_Agreement</targetReference>
        </faultConnector>
        <inputReference>col_PatientAgreements</inputReference>
    </recordCreates>
    <recordLookups>
        <name>Get_Patient_Agreement_Configuration</name>
        <label>Get Patient Agreement Configuration</label>
        <locationX>50</locationX>
        <locationY>782</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_through_passed_in_PAC</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_Error_Fetchig_Patient_Agreements</targetReference>
        </faultConnector>
        <filterLogic>1 AND NOT(2)</filterLogic>
        <filters>
            <field>Name</field>
            <operator>Contains</operator>
            <value>
                <stringValue>Informed Consent</stringValue>
            </value>
        </filters>
        <filters>
            <field>Name</field>
            <operator>Contains</operator>
            <value>
                <stringValue>PGT</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Patient_Agreement_Configuration__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Patient_Agreements</name>
        <label>Get Patient Agreements</label>
        <locationX>358</locationX>
        <locationY>134</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Log_Patient_Agreements</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_Error_Getting_Patient_Agreement</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Patient__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>rec_Account.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Patient_Agreement__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Patient_Agreement_Records</name>
        <label>Update Patient Agreement Records</label>
        <locationX>94</locationX>
        <locationY>5786</locationY>
        <connector>
            <targetReference>Log_Entry_Patient_Agreement_Records_Updated</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_Error_Updating_Patient_Agreements</targetReference>
        </faultConnector>
        <inputReference>col_PatientAgreementsToUpdate</inputReference>
    </recordUpdates>
    <start>
        <locationX>232</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Patient_Agreements</targetReference>
        </connector>
    </start>
    <status>Active</status>
