<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Work_Group_must_be_populated_on_Tier_2</fullName>
    <active>false</active>
    <description>Ensure this field is populated when the case has been escalated</description>
    <errorConditionFormula>AND(
    TEXT(Dispo_Level_3__c) = &quot;Escalation&quot;,
    ISBLANK(TEXT(Work_Group__c))
)</errorConditionFormula>
    <errorDisplayField>Work_Group__c</errorDisplayField>
    <errorMessage>Please select the work group for this Case.</errorMessage>
</ValidationRule>
