<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Case_Age_in_Days__c</fullName>
    <description>Number of days a Case has been open.</description>
    <externalId>false</externalId>
    <formula>IF(IsClosed, FLOOR(ClosedDate - CreatedDate), FLOOR(NOW() - CreatedDate))</formula>
    <label>Case Age in Days</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
