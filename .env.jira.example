# Copy to `.env.jira` and fill in values. Never commit `.env.jira`.
# See AGENTS.md for CaseOps GUI + Claude details.

# -----------------------------------------------------------------------------
# Jira API (jira_sync.py + CaseOps)
# -----------------------------------------------------------------------------
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-atlassian-api-token

# Optional: if set, takes precedence over email + token (prints Authorization header)
# JIRA_AUTH_HEADER_COMMAND=op read op://vault/item/field --no-newline
# JIRA_BEARER_TOKEN=
# JIRA_ASSIGNEE=
# JIRA_CLOUD_ID=

# -----------------------------------------------------------------------------
# CaseOps LLM mode (REQUIRED for full pipeline execution)
# claude_code  → spawn `claude` CLI; uses Claude Code subscription / claude login
#               → Enables agent tools (file, bash, Playwright, skills). Full Steps 1–12 work.
#               → Aliases: claude, subscription, max
# api_key      → Anthropic Messages API (text-only; no tools; install: pip install anthropic)
#               → Disables Steps 3–10 sub-agents. Use only if Skill execution is impossible.
#               → Optional tuning: CASEOPS_ANTHROPIC_MODEL, CASEOPS_ANTHROPIC_MAX_TOKENS
#
# RECOMMENDATION: Set to claude_code for full CaseOps pipeline (recommended)
# Set to api_key only if Claude Code subscription is unavailable.
# For api_key mode, ensure ANTHROPIC_API_KEY is set.
# For claude_code mode, run `claude login` first; API key is optional (omitted by Flask).
# -----------------------------------------------------------------------------
CASEOPS_LLM_AUTH=claude_code
# ANTHROPIC_API_KEY=sk-ant-api03-... (omit for claude_code; set for api_key mode)
# -----------------------------------------------------------------------------
# Azure DevOps (CaseOps escalation to ADO)
# PAT: Create at https://dev.azure.com/10xhealthsystem → User Settings → Personal access tokens
# Scopes: Work Items (Read & Write)
# -----------------------------------------------------------------------------
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=AxA...

# -----------------------------------------------------------------------------
# CaseOps / Salesforce conventions (some used by jira_sync or skills; adjust for your org)
# -----------------------------------------------------------------------------
CASEOPS_DEFAULT_ACTOR=operator-handle
CASEOPS_EXAMPLE_ASSIGNEE_NAME=Your Name
CASEOPS_SANDBOX_USERNAME_SUFFIX=.you
CASEOPS_DEFAULT_ASSIGNEE=you@example.com
CASEOPS_DEFAULT_TARGET_ORG=yourcompany-sandbox
CASEOPS_PRODUCTION_READ_ORG=yourcompany-prod
# Only org the pipeline may deploy to / write (skills/salesforce-sandbox-deploy-test). Required for Support deploy+test path.
CASEOPS_SANDBOX_TARGET_ORG=yourcompany-sandbox
CASEOPS_SALESFORCE_LIGHTNING_HOST=yourorg.lightning.force.com

# Frontdoor/session URLs — secrets; rotate when expired
CASEOPS_PRODUCTION_MAGIC_LINK=https://yourorg.my.salesforce.com/secur/frontdoor.jsp?sid=...
CASEOPS_SANDBOX_MAGIC_LINK=https://yourorg--sandbox.sandbox.my.salesforce.com/secur/frontdoor.jsp?sid=...

# Optional single link if you do not split prod vs sandbox (see AGENTS.md)
# CASEOPS_SALESFORCE_MAGIC_LINK=https://...

# Google Chrome Dev path for CaseOps-spawned `claude` (Windows example)
CASEOPS_CLAUDE_BROWSER=C:\Program Files\Google\Chrome Dev\Application\chrome.exe

# -----------------------------------------------------------------------------
# Optional: override defaults (caseops_paths / advanced)
# -----------------------------------------------------------------------------
# CASEOPS_JIRA_ENV_FILE=/absolute/path/.env.jira
# CASEOPS_JIRA_OUT_DIR=/absolute/path/to/outputs/jira
