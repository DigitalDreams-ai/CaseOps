.sf/
.sfdx/
.localdevserver/
deploy-options.json

# LWC
**/lwc/jsconfig.json
coverage/

# Robot Framework results
robot/Standard-Unlocked/results/

# Dependencies and tool caches
node_modules/
.eslintcache

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
outputs/logs/
logs/skill-runs/*.json

# CaseOps local Jira sync data can contain customer/support content.
caseops/data/jira/raw/*
