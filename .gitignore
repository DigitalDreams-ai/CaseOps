# Local environment and secrets
.env
.env.*
!.env.example
!.env.jira.example
.env.jira

# CaseOps local secrets
caseops/.env
caseops/.env.*
!caseops/.env.example

# Local deployment/runtime files. Use docker-compose.example.yml for sharing.
/docker-compose.yml
/claude-settings.json
HEAL-*_pipelineLogs.txt

# CCI
.cci
/src.orig
/src

# Python
__pycache__/
*.py[cod]
.pytest_cache/
caseops/__pycache__/
caseops/**/__pycache__/
caseops/**/*.pyc
caseops/.pytest_cache/

# Salesforce cache
.sf/
.sfdx/
.localdevserver/
deploy-options.json

# Root Salesforce/CumulusCI package templates are not part of CaseOps.
/cumulusci.yml
/pmd-rules.xml
/.forceignore
/sfdx-project.json
/robot/

# LWC
**/lwc/jsconfig.json
coverage/

# Dependencies and tool caches
node_modules/
.eslintcache

# Temporary metadata retrieval and testing (sf CLI)
temp/
temp-*/
temp_*/
temp_retrieve/
temp_admin_team/
temp-sf-retrieve/
C*temp-sf-retrieve/

# Retrieved Salesforce metadata must not be committed to CaseOps.
force-app/
field-retrieval/
flowexport/
flows/
orgs/
prod-metadata/
retrieve-prod/
retrieved_metadata/
retrieved_metadata_sharing/
unpackaged/
deploy-*/
deploy_*/
sandbox-deploy/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/skill-runs/*.json

# CaseOps local Jira sync data can contain customer/support content.
caseops/data/jira/raw/*
!caseops/data/jira/raw/.gitkeep
caseops/data/jira/summary/*
!caseops/data/jira/summary/.gitkeep
caseops/data/jira/attachments/*
!caseops/data/jira/attachments/.gitkeep
caseops/data/jira/*.json
caseops/data/jira/*.csv

# Generated artifacts
CaseOps_Image/
caseops/output/
outputs/jira/
outputs/production-metadata/
outputs/sandbox-metadata/
outputs/confidence-flags/
outputs/deployment-validation/
outputs/settings/

# Case work tracked on the work branch only
outputs/investigations/
outputs/internal-notes/
outputs/jira-messages/
outputs/test-reports/
outputs/engineering-escalations/
outputs/closed-resolved/
outputs/issue-summary-*.md
outputs/pipeline-logs/

# Editors
*.sublime-project
*.sublime-workspace
.vscode/
.idea/
.project
.settings/

# Multi-instance state directories (each instance has isolated .sfdx, .claude, outputs)
instance1/.sfdx/
instance1/.claude/
instance1/outputs/
instance1/temp-retrieve/
instance2/.sfdx/
instance2/.claude/
instance2/outputs/
instance2/temp-retrieve/

# Local assistant/session data (track CaseOps Claude Code skill stub under .claude/skills/)
.claude/*
!.claude/skills/
!.claude/skills/jira-salesforce-fix-pipeline/
!.claude/skills/jira-salesforce-fix-pipeline/SKILL.md
!.claude/plans/
!.claude/plans/*.md
.playwright-mcp/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/
settings-page-snapshot.md
