<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Referred_By__c</fullName>
    <deleteConstraint>Restrict</deleteConstraint>
    <description>Based on the Affiliate Code field on the opportunity this field will be filled in by whom ever is a match to that referral code.</description>
    <label>Referred By</label>
    <lookupFilter>
        <active>true</active>
        <filterItems>
            <field>Account.Referral_Code__c</field>
            <operation>notEqual</operation>
            <value></value>
        </filterItems>
        <isOptional>true</isOptional>
    </lookupFilter>
    <referenceTo>Account</referenceTo>
    <relationshipLabel>Opportunities (Referred By)</relationshipLabel>
    <relationshipName>Influenced_Opportunities</relationshipName>
    <required>false</required>
    <trackFeedHistory>false</trackFeedHistory>
    <trackHistory>true</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Lookup</type>
</CustomField>
