    <formulas>
        <name>form_numHeightMetric</name>
        <dataType>Number</dataType>
        <expression>IF(
    NOT(ISBLANK({!rec_LabOrder.Height__c})), 
    {!rec_LabOrder.Height__c} * 2.54, 
    IF(
        NOT(ISBLANK({!rec_LabOrder.Patient__r.Patient_Height_cm__c})), 
        {!rec_LabOrder.Patient__r.Patient_Height_cm__c}, 
        0.00
    )
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>form_numWeightMetric</name>
        <dataType>Number</dataType>
        <expression>IF(
    NOT(ISBLANK({!rec_LabOrder.Weight__c})), 
    {!rec_LabOrder.Weight__c} / 2.20462, 
    IF(
        NOT(ISBLANK({!rec_LabOrder.Patient__r.Patient_Weight_kg__c})), 
        {!rec_LabOrder.Patient__r.Patient_Weight_kg__c}, 
        0.00
    )
)</expression>
        <scale>6</scale>
    </formulas>
