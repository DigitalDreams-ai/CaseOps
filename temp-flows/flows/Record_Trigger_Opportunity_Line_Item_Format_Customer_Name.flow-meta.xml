<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Before save flow that will run when OLI is created with a Customer Name filled in or when updated with new Customer Name. It will remove unnecessary white spaces</description>
    <environments>Default</environments>
    <formulas>
        <description>Formats customer name by removing unnecessary spaces &quot;  &quot;</description>
        <name>txt_FormatCustomerName</name>
        <dataType>String</dataType>
        <expression>TRIM(
    SUBSTITUTE(
        SUBSTITUTE(
            SUBSTITUTE(
                {!$Record.Customer_Name_GT__c}, &quot;    &quot;, &quot; &quot;
            ), &quot;   &quot;, &quot; &quot;
        ), &quot;  &quot;, &quot; &quot;
    )
)</expression>
    </formulas>
    <formulas>
        <name>txt_FormatGender</name>
        <dataType>String</dataType>
        <expression>IF(
    BEGINS(UPPER({!$Record.Gender__c}), &quot;M&quot;), 
    &quot;Male&quot;, 
    IF(
        BEGINS(UPPER({!$Record.Gender__c}), &quot;F&quot;), 
        &quot;Female&quot;, 
        {!$Record.Gender__c}
    )
)</expression>
    </formulas>
    <interviewLabel>Recor {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Opportunity Line Item - Format Customer Name</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Update formatted customer name</description>
        <name>Update_Customer_Name</name>
        <label>Update Customer Name</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <inputAssignments>
            <field>Customer_Name_GT__c</field>
            <value>
                <elementReference>txt_FormatCustomerName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Gender__c</field>
            <value>
                <elementReference>txt_FormatGender</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Customer_Name</targetReference>
        </connector>
        <filterFormula>OR(
    AND(ISNEW(), NOT(ISBLANK({!$Record.Customer_Name_GT__c}))),
    ISCHANGED({!$Record.Customer_Name_GT__c}),
 ISCHANGED({!$Record.Gender__c})
)</filterFormula>
        <object>OpportunityLineItem</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
