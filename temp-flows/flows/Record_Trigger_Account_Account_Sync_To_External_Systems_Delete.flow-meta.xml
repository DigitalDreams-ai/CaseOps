<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>This triggered flow will sync with the external API system to keep the Patient data updated in all remote systems.</description>
    <environments>Default</environments>
    <interviewLabel>Record Trigger - Account - Account Sync To External Systems - Delete {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Account - Account Sync To External Systems - Delete</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Delete_Account_From_External_Systems</targetReference>
        </connector>
        <filterFormula>{!$Record.RecordType.DeveloperName} = &apos;Patient_Account_Record_Type&apos;</filterFormula>
        <object>Account</object>
        <recordTriggerType>Delete</recordTriggerType>
        <triggerType>RecordBeforeDelete</triggerType>
    </start>
    <status>Draft</status>
    <subflows>
        <name>Delete_Account_From_External_Systems</name>
        <label>Delete Account From External Systems</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <flowName>Autolaunch_Account_Sync_To_External_Systems</flowName>
        <inputAssignments>
            <name>bool_IsNew</name>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>rec_Account</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>txt_EventType</name>
            <value>
                <stringValue>DeleteAccount</stringValue>
            </value>
        </inputAssignments>
    </subflows>
    <variables>
        <name>apexDefined_EventDetails</name>
        <apexClass>Patient_DS_Event</apexClass>
        <dataType>Apex</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>apexDefined_PatientDetails</name>
        <apexClass>Patient_DS_Patient</apexClass>
        <dataType>Apex</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
