    <decisions>
        <description>Not all labs support updating the order, which we will give an error when this happens.</description>
        <name>Does_Lab_Support_API_Update_Order</name>
        <label>Does Lab Support API - Update Order</label>
        <locationX>336</locationX>
        <locationY>1058</locationY>
        <defaultConnector>
            <targetReference>Log_Lab_Doesn_t_Support_Update_Order</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Lab Supports Update Order</defaultConnectorLabel>
        <rules>
            <name>Lab_Support_Update_Order</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId.Lab_Provider_Configuration__r.Available_APIs__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Update Order</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Screenflow_In_Person_Kit_Register_Update_Lab_Order_Flow_1</targetReference>
            </connector>
            <label>Lab Support Update Order</label>
        </rules>
    </decisions>
    <decisions>
        <description>If we are updating order and lab provider configuration is missing, we need to assign (mostly legacy orders)</description>
        <name>Is_Lab_Provider_Configuration_Missing</name>
        <label>Is Lab Provider Configuration Missing</label>
        <locationX>336</locationX>
        <locationY>242</locationY>
        <defaultConnector>
            <targetReference>Does_Lab_Support_API_Update_Order</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Lab Provider Configuration Present</defaultConnectorLabel>
        <rules>
            <name>Lab_Provider_Configuration_Missing</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId.Lab_Provider_Configuration__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_Lab_Provider_selected_in_the_Picklist</targetReference>
            </connector>
            <label>Lab Provider Configuration Missing</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if the picklist field already has a Lab Provider selected (legacy orders)</description>
        <name>Is_Lab_Provider_selected_in_the_Picklist</name>
        <label>Is Lab Provider selected in the Picklist</label>
        <locationX>182</locationX>
        <locationY>350</locationY>
        <defaultConnector>
            <targetReference>Set_Lab_Provider</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Lab Provider selected</defaultConnectorLabel>
        <rules>
            <name>Lab_Provider_selected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId.Lab_Provider__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Lab_Provider</targetReference>
            </connector>
            <label>Lab Provider selected</label>
        </rules>
    </decisions>
