# Copy to `.env` next to docker-compose.yml and fill in values.
# Never commit or share a real `.env` file.

# -----------------------------------------------------------------------------
# Jira API (jira_sync.py + CaseOps)
# -----------------------------------------------------------------------------
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-atlassian-api-token

# -----------------------------------------------------------------------------
# CaseOps LLM mode (REQUIRED for full pipeline execution)
# claude_code  → spawn `claude` CLI; uses Claude Code subscription OAuth token
#               → Enables agent tools (file, bash, Playwright, skills). Full Steps 1–12 work.
#               → Aliases: claude, subscription, max
# For claude_code mode, run `claude setup-token` and save the token in Settings.
# -----------------------------------------------------------------------------
CASEOPS_LLM_AUTH=claude_code
# CLAUDE_CODE_OAUTH_TOKEN=... (recommended: paste through Settings after running `claude setup-token`)

# -----------------------------------------------------------------------------
# CaseOps / Salesforce conventions (some used by jira_sync or skills; adjust for your org)
# -----------------------------------------------------------------------------
CASEOPS_DEFAULT_ACTOR=operator-handle
CASEOPS_EXAMPLE_ASSIGNEE_NAME=Your Name
CASEOPS_SANDBOX_USERNAME_SUFFIX=.you
CASEOPS_DEFAULT_ASSIGNEE=you@example.com
CASEOPS_DEFAULT_TARGET_ORG=yourcompany-sandbox
CASEOPS_PRODUCTION_READ_ORG=yourcompany-prod
# Only org the pipeline may deploy to / write (skills/salesforce-sandbox-deploy-test). Required for Support deploy+test path.
CASEOPS_SANDBOX_TARGET_ORG=yourcompany-sandbox
CASEOPS_PRODUCTION_INSTANCE_URL=https://login.salesforce.com
CASEOPS_SANDBOX_INSTANCE_URL=https://test.salesforce.com
CASEOPS_SALESFORCE_LIGHTNING_HOST=yourorg.lightning.force.com

# Salesforce tokens used by CaseOps runtime and optional sf CLI auth.
# Get access tokens with: sf org auth show-access-token -o <alias> --json
# For auto-refresh, paste result.sfdxAuthUrl from: sf org auth show-sfdx-auth-url -o <alias> --json
SF_PROD_ACCESS_TOKEN=
SF_PROD_REFRESH_TOKEN=

SF_SANDBOX_ACCESS_TOKEN=
SF_SANDBOX_REFRESH_TOKEN=

SF_TOKENS_REFRESHED_AT=

# Frontdoor/session URLs — secrets; rotate when expired
CASEOPS_PRODUCTION_MAGIC_LINK=
CASEOPS_SANDBOX_MAGIC_LINK=

# Optional single link if you do not split prod vs sandbox.
# CASEOPS_SALESFORCE_MAGIC_LINK=https://...

# Optional browser path for CaseOps-spawned `claude` visual checks.
# Usually leave unset in Docker unless you intentionally provide a browser.
#CASEOPS_CLAUDE_BROWSER=

# -----------------------------------------------------------------------------
# Runtime tuning
# -----------------------------------------------------------------------------
# Auto-Process All / Reprocess All issue worker count. Single issue runs still
# use one orchestrator. Keep at 1 unless the instance has enough CPU/RAM and
# Salesforce/Jira rate limits are comfortable.
CASEOPS_GLOBAL_MAX_PARALLEL=1

# Maximum Auto-Process All / Reprocess All queue passes before stopping. CaseOps
# also stops earlier if no issue advances, to avoid repeating the same failures.
CASEOPS_GLOBAL_MAX_QUEUE_PASSES=12

# Optional parallel read-only checks. Deploy and sandbox test steps remain
# serialized for a single issue.
CASEOPS_ENABLE_PARALLEL_PRECHECKS=false
CASEOPS_ENABLE_PARALLEL_EVIDENCE_BRANCHES=false

# Similar issues similarity clustering (Phase 1: deterministic index + automatic clusters).
CASEOPS_SIMILAR_ISSUES_ENABLED=true
CASEOPS_SIMILAR_ISSUES_INCLUDE_CLOSED=true
CASEOPS_SIMILAR_ISSUES_CURRENT_USER_ONLY=true
CASEOPS_SIMILAR_ISSUES_AUTO_CLUSTER=true
CASEOPS_SIMILAR_ISSUES_PUBLIC_SAFE_SUMMARIES=true
CASEOPS_SIMILAR_ISSUES_PIPELINE_CONTEXT=false
CASEOPS_SIMILAR_ISSUES_MODEL_ADJUDICATION=false
CASEOPS_SIMILAR_ISSUES_DELTA_MODE=false
CASEOPS_SIMILAR_ISSUES_CANDIDATE_LIMIT=15
CASEOPS_SIMILAR_ISSUES_LOOKBACK_DAYS=180
# Optional; defaults to CASEOPS_DEFAULT_ASSIGNEE/JIRA_EMAIL when omitted.
CASEOPS_SIMILAR_ISSUES_CURRENT_USER=

# Scheduled Jira sync. The checkbox in Settings is the primary control; 0
# minutes also disables interval syncs for compatibility.
CASEOPS_AUTO_SYNC_ENABLED=false
CASEOPS_AUTO_SYNC_INTERVAL_MINUTES=0

# Flask debug output. Keep false for shared/tester instances.
CASEOPS_FLASK_DEBUG=false

# Claude subprocess guardrails. Increase total timeout for large issues that
# need long metadata/deploy/test cycles.
CASEOPS_CLAUDE_IDLE_TIMEOUT_SECONDS=240
CASEOPS_CLAUDE_TOTAL_TIMEOUT_SECONDS=1200

# -----------------------------------------------------------------------------
# Optional: override defaults (caseops_paths / advanced)
# -----------------------------------------------------------------------------
# CASEOPS_JIRA_OUT_DIR=/absolute/path/to/outputs/jira
