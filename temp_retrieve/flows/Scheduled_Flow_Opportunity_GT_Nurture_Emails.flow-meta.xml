    <description>This scheduled flow will run every day at 9AM EST and will send out nurture emails to GT Oppty if the Stage is in Kit Needs Sent or Pending Results. There will be two different emails depending on of they are in person ( Not Required Shipping ) or virtual ( Requires Shipping ).</description>
    <environments>Default</environments>
    <formulas>
        <name>formNum_EmailSentInLastSevenDays</name>
        <dataType>Number</dataType>
        <expression>IF ( ISNULL({!$Record.Last_Nurture_Email_Sent__c}), 7,TODAY() - DATEVALUE({!$Record.Last_Nurture_Email_Sent__c}))</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>Scheduled Flow - Opportunity - GT Nurture Emails {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Scheduled Flow - Opportunity - GT Nurture Emails</label>
