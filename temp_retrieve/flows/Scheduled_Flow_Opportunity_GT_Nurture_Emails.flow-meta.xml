    <start>
        <locationX>633</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Has_Nuture_Email_Been_Sent_in_the_last_7_Days</targetReference>
        </connector>
        <filterLogic>( 1 OR 2 ) AND 3 AND ( 4 OR 5 )</filterLogic>
        <filters>
            <field>StageName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Kit Sent</stringValue>
            </value>
        </filters>
        <filters>
            <field>StageName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Pending Results</stringValue>
            </value>
        </filters>
        <filters>
            <field>CreatedDate</field>
            <operator>GreaterThan</operator>
            <value>
                <dateTimeValue>2023-02-13T04:59:00.000Z</dateTimeValue>
            </value>
        </filters>
        <filters>
            <field>Number_of_Nurture_Emails_Sent__c</field>
            <operator>LessThan</operator>
            <value>
                <numberValue>6.0</numberValue>
            </value>
        </filters>
        <filters>
            <field>Number_of_Nurture_Emails_Sent__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
