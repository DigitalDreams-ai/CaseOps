    <decisions>
        <description>If the nurture email has been sent within the last seven days we do no need to send another email. If the nurture email hasn&apos;t been sent within the last seven days we will send an email to the patient.</description>
        <name>Has_Nuture_Email_Been_Sent_in_the_last_7_Days</name>
        <label>Has Nuture Email Been Sent in the last 7 Days</label>
        <locationX>759</locationX>
        <locationY>276</locationY>
        <defaultConnector>
            <targetReference>Is_This_In_Person_or_Virtual</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Email Has Not Been Sent Within the last seven days</defaultConnectorLabel>
        <rules>
            <name>Email_Sent_Within_the_Last_7_Days</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>formNum_EmailSentInLastSevenDays</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>7.0</numberValue>
                </rightValue>
            </conditions>
            <label>Email Sent Within the Last 7 Days</label>
        </rules>
    </decisions>
