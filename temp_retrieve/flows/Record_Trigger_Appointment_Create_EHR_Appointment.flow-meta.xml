<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>When there is a new Appointment record created, and the Appointment Type is Blood Review, we will create a new EHR appointment.</description>
    <environments>Default</environments>
    <interviewLabel>Record Trigger - Appointment - Create EHR Appointment {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Appointment - Create EHR Appointment</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <filterFormula>AND(
          NOT(ISNULL({!$Record.Account__r.DrChrono_Id__c})),
          ISPICKVAL({!$Record.appointment_Status__c}, &quot;Scheduled&quot;),
          ISBLANK({!$Record.Appointment_Id__c}),
          NOT(ISNULL({!$Record.Provider_Account__c})),
          NOT(ISNULL({!$Record.Provider_Account__r.DrChrono_Id__c})),
          NOT(ISNULL({!$Record.Opportunity__c})),
          {!$Record.Opportunity__r.RecordType.DeveloperName} = &quot;Consultation&quot;
)</filterFormula>
        <object>Appointment__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <scheduledPaths>
            <connector>
                <targetReference>Create_Appointment</targetReference>
            </connector>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Create_Appointment</name>
        <label>Create Appointment</label>
        <locationX>308</locationX>
        <locationY>276</locationY>
        <flowName>Autolaunch_EHR_Appointment</flowName>
        <inputAssignments>
            <name>rec_Appointment</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
    </subflows>
</Flow>
