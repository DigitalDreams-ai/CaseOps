<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>This flow will trigger when the API has updated the Patient Document Signed date. This flow will then create a task for the Patient Document team to review the document.</description>
    <environments>Default</environments>
    <formulas>
        <name>form_TaskDueDate</name>
        <dataType>Date</dataType>
        <expression>{!$Flow.CurrentDate}+5</expression>
    </formulas>
    <formulas>
        <name>form_TaskSubject</name>
        <dataType>String</dataType>
        <expression>&apos;Patient &apos; + TEXT({!$Record.Agreement_Type__c}) + &apos;Received: &apos; + {!$Record.Name}</expression>
    </formulas>
    <interviewLabel>Record Trigger {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger - Patient Document Received</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Date_Signed__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Date_Signed__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Creation_Source__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Shopify</stringValue>
            </value>
        </filters>
        <object>Patient_Agreement__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <scheduledPaths>
            <connector>
                <targetReference>Autolaunch_Patient_Agreement_Received</targetReference>
            </connector>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
    <subflows>
        <name>Autolaunch_Patient_Agreement_Received</name>
        <label>Autolaunch - Patient Agreement Received</label>
        <locationX>308</locationX>
        <locationY>276</locationY>
        <flowName>Autolaunch_Patient_Agreement_Received</flowName>
        <inputAssignments>
            <name>rec_PatientAgreement</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
    </subflows>
    <triggerOrder>100</triggerOrder>
    <variables>
        <name>rec_Task</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Task</objectType>
    </variables>
</Flow>
