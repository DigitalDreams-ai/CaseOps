    <decisions>
        <name>Is_the_Lead_a_Franchisee</name>
        <label>Is the Lead a Franchisee or Licensee?</label>
        <locationX>1304</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>YesFranchisee</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Lead_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Franchisee</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>What_is_the_Status_of_the_Franchisee</targetReference>
            </connector>
            <label>YesFranchisee</label>
        </rules>
        <rules>
            <name>YesLicensee</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Lead_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Licensee</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>What_is_the_status_of_the_licensee</targetReference>
            </connector>
            <label>YesLicensee</label>
        </rules>
    </decisions>
    <decisions>
        <name>What_is_the_Status_of_the_Franchisee</name>
        <label>What is the Status of the Franchisee?</label>
        <locationX>446</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>New_Franchisee</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>isNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Intro_Email_To_Franchisee</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>New Franchisee</label>
        </rules>
        <rules>
            <name>UnqualifiedFranchisee</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Unqualified</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Unqualified_Franchisee_Email</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Unqualified Franchisee</label>
        </rules>
        <rules>
            <name>FranchiseeApproved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Application Approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
