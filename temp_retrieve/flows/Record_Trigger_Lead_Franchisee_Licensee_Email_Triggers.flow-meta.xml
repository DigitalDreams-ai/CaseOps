    <description>A flow that sends emails to franchisee or licensee leads when they are created and progress through the lead process</description>
    <environments>Default</environments>
    <formulas>
        <name>form_txt_LeadLink</name>
        <dataType>String</dataType>
        <expression>{!txt_BaseUrl} + {!$Record.Id}</expression>
    </formulas>
    <formulas>
        <name>isNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>txt_BaseUrl</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_600}, FIND( &apos;/services&apos;, {!$Api.Partner_Server_URL_600}))</expression>
    </formulas>
