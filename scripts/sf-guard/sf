#!/usr/bin/env bash
set -euo pipefail

REAL_SF="${CASEOPS_REAL_SF:-/usr/local/bin/sf}"

if [[ ! -x "$REAL_SF" ]]; then
  echo "CaseOps sf guard: real Salesforce CLI not executable: $REAL_SF" >&2
  exit 127
fi

prod_aliases=()
[[ -n "${CASEOPS_PRODUCTION_READ_ORG:-}" ]] && prod_aliases+=("$CASEOPS_PRODUCTION_READ_ORG")
[[ -n "${CASEOPS_PRODUCTION_ORG:-}" ]] && prod_aliases+=("$CASEOPS_PRODUCTION_ORG")

target_org=""
args=("$@")
for ((i=0; i<${#args[@]}; i++)); do
  case "${args[$i]}" in
    --target-org|--targetusername|-o|-u)
      if (( i + 1 < ${#args[@]} )); then
        target_org="${args[$((i+1))]}"
      fi
      ;;
    --target-org=*|--targetusername=*)
      target_org="${args[$i]#*=}"
      ;;
  esac
done

is_mutating=0
first="${1:-}"
second="${2:-}"
third="${3:-}"

case "$first $second" in
  "data create"|"data update"|"data delete"|"data upsert"|"data import"|"data tree"|"project deploy"|"project delete"|"apex run"|"org assign")
    is_mutating=1
    ;;
esac

case "$first $second $third" in
  "data create record"|"data update record"|"data delete record"|"data upsert bulk"|"project deploy start"|"project delete source"|"apex run test"|"org assign permset"|"org assign permsetlicense")
    is_mutating=1
    ;;
esac

case "$first" in
  force:data:*:create|force:data:*:update|force:data:*:delete|force:source:deploy|force:mdapi:deploy|force:apex:execute|force:user:permset:assign)
    is_mutating=1
    ;;
esac

if [[ "$is_mutating" == "1" ]]; then
  if [[ -z "$target_org" ]]; then
    echo "CaseOps sf guard: blocked mutating sf command without explicit --target-org/-o. Use the allowlisted Sandbox alias for writes." >&2
    exit 64
  fi
  for prod in "${prod_aliases[@]}"; do
    if [[ -n "$prod" && "$target_org" == "$prod" ]]; then
      now="$(date +%s)"
      approved="${CASEOPS_PRODUCTION_WRITE_APPROVED:-}"
      issue_key="${CASEOPS_PRODUCTION_WRITE_ISSUE_KEY:-}"
      expires_at="${CASEOPS_PRODUCTION_WRITE_EXPIRES_AT:-0}"
      approval_file="${CASEOPS_PRODUCTION_WRITE_APPROVAL_FILE:-}"
      audit_log="${CASEOPS_PRODUCTION_WRITE_AUDIT_LOG:-}"
      request_hash="${CASEOPS_PRODUCTION_WRITE_REQUEST_HASH:-}"
      if [[ "$approved" == "1" && -n "$issue_key" && "$expires_at" =~ ^[0-9]+$ && "$now" -le "$expires_at" ]]; then
        if [[ -z "$approval_file" || ! -f "$approval_file" ]]; then
          echo "CaseOps sf guard: blocked Production mutation; approval marker is missing." >&2
          exit 64
        fi
        if ! python3 - "$approval_file" "$issue_key" "$request_hash" <<'PY'
import json
import sys
import time

path, issue_key, request_hash = sys.argv[1:4]
try:
    with open(path, "r", encoding="utf-8") as handle:
        marker = json.load(handle)
except Exception as exc:
    print(f"CaseOps sf guard: blocked Production mutation; approval marker is unreadable: {exc}", file=sys.stderr)
    sys.exit(1)

if marker.get("status") != "active":
    print("CaseOps sf guard: blocked Production mutation; approval marker is not active.", file=sys.stderr)
    sys.exit(1)
if marker.get("issue_key") != issue_key:
    print("CaseOps sf guard: blocked Production mutation; approval marker issue mismatch.", file=sys.stderr)
    sys.exit(1)
if request_hash and marker.get("request_hash") != request_hash:
    print("CaseOps sf guard: blocked Production mutation; approval request hash mismatch.", file=sys.stderr)
    sys.exit(1)
try:
    expires_at = int(marker.get("expires_at_epoch") or 0)
except (TypeError, ValueError):
    expires_at = 0
if int(time.time()) > expires_at:
    print("CaseOps sf guard: blocked Production mutation; approval marker expired.", file=sys.stderr)
    sys.exit(1)
PY
        then
          exit 64
        fi
        if [[ -z "$audit_log" ]]; then
          echo "CaseOps sf guard: blocked Production mutation; audit log path is missing." >&2
          exit 64
        fi
        {
          printf '%s issue=%s target=%s command=' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$issue_key" "$target_org"
          printf '%q ' "$@"
          printf '\n'
        } >> "$audit_log"
        echo "CaseOps sf guard: temporary Production write approval active for $issue_key; allowing explicit Production target '$target_org'." >&2
        break
      fi
      echo "CaseOps sf guard: blocked mutating sf command against Production alias '$target_org'. Production is read-only unless a valid one-run Production approval is active." >&2
      exit 64
    fi
  done
fi

exec "$REAL_SF" "$@"
